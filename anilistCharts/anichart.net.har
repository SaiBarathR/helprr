e\\/banner\\/206951-P1BNNpbqN4zG.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206951-qiHcrw7pwzuq.jpg\",\"color\":\"#5dc9f1\"},\"trailer\":{\"id\":\"suKjfBsH3UM\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/suKjfBsH3UM\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/rokkotsu_anime\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/rokkotsu_anime\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/rokkotsu-anime.com\\/\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/@rokkotsu-anime\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GT00371665\\/my-ribdiculous-reincarnation\"}],\"rankings\":[{\"rank\":68,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":95,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7092,\"name\":\"Qzil.la\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7092\"},{\"id\":6857,\"name\":\"S.o.K\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6857\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":206959,\"title\":{\"romaji\":\"Megami \\u201cIsekai Tensei Nani ni Naritai desu ka\\u201d Ore \\u201cYuusha no Rokkotsu de\\u201d\",\"native\":\"\\u5973\\u795e\\u300c\\u7570\\u4e16\\u754c\\u8ee2\\u751f\\u4f55\\u306b\\u306a\\u308a\\u305f\\u3044\\u3067\\u3059\\u304