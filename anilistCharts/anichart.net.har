            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":false,\"total\":159},\"media\":[{\"id\":200455,\"idMal\":null,\"title\":{\"romaji\":\"Yowaki MAX Reijou Nano ni, Ratsuwan Konyakusha-sama no Kake ni Notte Shimatta\",\"native\":\"\\u5f31\\u6c17MAX\\u4ee4\\u5b22\\u306a\\u306e\\u306b\\u3001\\u8fa3\\u8155\\u5a5a\\u7d04\\u8005\\u69d8\\u306e\\u8ced\\u3051\\u306b\\u4e57\\u3063\\u3066\\u3057\\u307e\\u3063\\u305f\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Comedy\",\"Fantasy\",\"Romance\"],\"synonyms\":[\"Even Though I'm a Super Timid Noble Girl, I Accepted the Bet From My Cunning Fianc\\u00e9\"],\"duration\":null,\"popularity\":774,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/200455\",\"description\":\"I was reborn as a villainous daughter in a reverse harem otome game. \\n<br><br>\\nAfter being sick with a high fever at the age of 10, Pia Rockwell suddenly remembered her past life as a university student in Japan. But far from going down the villainess route, all this super timid girl wants is to finally use her knowledge from when she was a grad student studying to get her doctorate in paleontology. Her ultimate goal is to become a commoner, excavate fossils, build a museum and then become a curator.\\n<br><br>\\nSo in order to escape the villainess route and avoid being deported by her fianc\\u00e9 during the graduation ball, Pia decides to avoid the upcoming hurt and heartache and asks to break off her engagement to Rufus, the Prime Minister's son.\\n<br><br>\\nBut will her cunning fianc\\u00e9 let her go that easily?\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b200455-gpDWDkMAEuM7.jpg\",\"color\":\"#f1865d\"},\"trailer\":{\"id\":\"DhjCaXRX73k\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/DhjCaXRX73k\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/yowaki-max-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/yowaki_max\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":151603,\"title\":{\"romaji\":\"Yowaki MAX Reijou Nano ni, Ratsuwan Konyakusha-sama no Kake ni Notte Shimatta\",\"native\":\"\\u5f31\\u6c17MAX\\u4ee4\\u5b22\\u306a\\u306e\\u306b\\u3001\\u8fa3\\u8155\\u5a5a\\u7d04\\u8005\\u69d8\\u306e\\u8ced\\u3051\\u306b\\u4e57\\u3063\\u3066\\u3057\\u307e\\u3063\\u305f\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/151603\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":151602,\"title\":{\"romaji\":\"Yowaki MAX Reijou Nano ni, Ratsuwan Konyakusha-sama no Kake ni Notte Shimatta\",\"native\":\"\\u5f31\\u6c17MAX\\u4ee4\\u5b22\\u306a\\u306e\\u306b\\u3001\\u8fa3\\u8155\\u5a5a\\u7d04\\u8005\\u69d8\\u306e\\u8ced\\u3051\\u306b\\u4e57\\u3063\\u3066\\u3057\\u307e\\u3063\\u305f\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/151602\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":184072,\"idMal\":60267,\"title\":{\"romaji\":\"Yuru Camp\\u25b3 SEASON 4\",\"native\":\"\\u3086\\u308b\\u30ad\\u30e3\\u30f3\\u25b3 SEASON\\uff14\",\"english\":null},\"startDate\":{\"year\":2027,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Comedy\",\"Slice of Life\"],\"synonyms\":[\"Laid-Back Camp Season 4\"],\"duration\":null,\"popularity\":8636,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3086\\u308b\\u30ad\\u30e3\\u30f3\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/184072\",\"description\":\"The fourth season of <i>Yuru Camp\\u25b3<\\/i>.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx184072-oF3L8oVi7VM9.jpg\",\"color\":\"#f1a143\"},\"trailer\":{\"id\":\"pNDkVOlaGBQ\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/pNDkVOlaGBQ\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/yurucamp.jp\\/fourth\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/yurucamp_anime\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/yurucamp_insta\\/\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@yurucamp_anime\"}],\"rankings\":[{\"rank\":9,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7792,\"name\":\"FuRyu Pictures\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7792\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":155908,\"title\":{\"romaji\":\"Yuru Camp\\u25b3 SEASON 3\",\"native\":\"\\u3086\\u308b\\u30ad\\u30e3\\u30f3\\u25b3 SEASON\\uff13\",\"english\":\"Laid-Back Camp Season 3\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/155908\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":98351,\"title\":{\"romaji\":\"Yuru Camp\\u25b3\",\"native\":\"\\u3086\\u308b\\u30ad\\u30e3\\u30f3\\u25b3\",\"english\":\"Laid-Back Camp\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/98351\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":207328,\"idMal\":null,\"title\":{\"romaji\":\"Yuukyuu no Gusha Asley no, Kenja no Susume\",\"native\":\"\\u60a0\\u4e45\\u306e\\u611a\\u8005\\u30a2\\u30ba\\u30ea\\u30fc\\u306e\\u3001\\u8ce2\\u8005\\u306e\\u3059\\u309d\\u3081\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Comedy\",\"Fantasy\",\"Romance\",\"Supernatural\"],\"synonyms\":[\"The Eternal Fool's Words of Wisdom: A Pawsitively Fantastic Adventure\",\"The Eternal Fool's Words of Wisdom\"],\"duration\":null,\"popularity\":379,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30a2\\u30cb\\u30e1\\u30a2\\u30ba\\u30ea\\u30fc\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/207328\",\"description\":\"A couple thousand years of solitude would wear down any young man\\u2014that is, anyone except Asley, an eternally youthful and eternally foolish sorcerer. After all, he has man's best friend...er, familiar, to keep him company. When his Level 100 canine companion Pochi demands that he get some fresh air for the first time in two centuries, Asley sets out to reintegrate into society and test his magic mettle. His mission? Dropping several unglamorous titles from his repertoire and restoring his good (okay, decent) name.\\n<br><br>\\nA brand-new world and fresh adventures await Asley after his many years of hermitage. Perhaps he'll lend Pochi a hand to place first in the mysterious Familiar Feud. Or maybe he'll lose all vestiges of dignity and turn tail. Whichever comes first! No matter what, Asley has great evil to fight, a big world to save, and even a little growing up to do...that is, if he can endure Pochi's \\u201cfriendly advice\\u201d along the way!\\n<br><br>\\n(Source: J-Novel Club)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx207328-BVD3Qa5lrUG3.jpg\",\"color\":\"#e4bba1\"},\"trailer\":{\"id\":\"vxzEz8iSQ1U\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/vxzEz8iSQ1U\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/asley_anime\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":95939,\"title\":{\"romaji\":\"Yuukyuu no Gusha Asley no, Kenja no Susume\",\"native\":\"\\u60a0\\u4e45\\u306e\\u611a\\u8005\\u30a2\\u30ba\\u30ea\\u30fc\\u306e\\u3001\\u8ce2\\u8005\\u306e\\u3059\\u309d\\u3081\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/95939\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":101516,\"title\":{\"romaji\":\"Yuukyuu no Gusha Asley no, Kenja no Susume: to, Pochi no Daibouken\",\"native\":\"\\u60a0\\u4e45\\u306e\\u611a\\u8005\\u30a2\\u30ba\\u30ea\\u30fc\\u306e\\u3001\\u8ce2\\u8005\\u306e\\u3059\\u309d\\u3081 \\u2015\\u3068\\u3001\\u30dd\\u30c1\\u306e\\u5927\\u5192\\u967a\\u2015\",\"english\":\"The Eternal Fool's Words of Wisdom: A Pawsitively Fantastic Adventure\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/101516\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":209963,\"idMal\":63820,\"title\":{\"romaji\":\"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku 2nd Season\",\"native\":\"\\u52c7\\u8005\\u5211\\u306b\\u51e6\\u3059 \\u61f2\\u7f70\\u52c7\\u80059004\\u968a\\u5211\\u52d9\\u8a18\\u9332 \\u7b2c2\\u671f\",\"english\":\"Sentenced to Be a Hero Season 2\"},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Action\",\"Drama\",\"Fantasy\"],\"synonyms\":[],\