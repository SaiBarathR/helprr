cdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/gachiakuta_PR\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/gachiakuta-anime.com\\/\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/gachiakuta_PR\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@gachiakuta_PR\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":178025,\"title\":{\"romaji\":\"Gachiakuta\",\"native\":\"\\u30ac\\u30c1\\u30a2\\u30af\\u30bf\",\"english\":\"Gachiakuta\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/178025\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":144946,\"title\":{\"romaji\":\"Gachiakuta\",\"native\":\"\\u30ac\\u30c1\\u30a2\\u30af\\u30bf\",\"english\":\"Gachiakuta\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/144946\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":209224,\"idMal\":63706,\"title\":{\"romaji\":\"Game Sekai Tensei <Dankatsu>: Gamer wa [Dungeon Shuukatsu no Susume] wo <Hajime kara> Play Suru\",\"native\":\"\\u30b2\\u30fc\\u30e0\\u4e16\\u754c\\u8ee2\\u751f\\u3008\\u30c0\\u30f3\\u6d3b\\u3009\\uff5e\\u30b2\\u30fc\\u30de\\u30fc\\u306f\\u3010\\u30c0\\u30f3\\u30b8\\u30e7\\u30f3\\u5c31\\u6d3b\\u306e\\u30b9\\u30b9\\u30e1\\u3011\\u3092\\u3008\\u306f\\u3058\\u3081\\u304b\\u3089\\u3009\\u30d7\\u30ec\\u30a4\\u3059\\u308b\\uff5e\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\",\"Romance\"],\"synonyms\":[\"Reincarnation in the Game World Dan-Katsu: Game Addict Plays \\\"Encouragement for Job Hunting in Dungeons\\\" From a \\\"New Game\\\"\"],\"duration\":null,\"popularity\":420,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30c0\\u30f3\\u6d3b\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/209224\",\"description\":\"Dan-Katsu is a legendary role-playing game that allows you to play more than 1021 classes and has more than 400 possible endings! The more we delve into it, the more we discover new ways to enjoy it, new objects\\u2026 A certain gamer (player name: Zephyrus) is reincarnated in the world of Dan-Katsu, of which he becomes the main character. Overjoyed, he joins the Labyrinth Academy, the place where the main story takes place. He quickly obtains the 'Hero' class, the best in the game, but discovers that the 'Muscle Warrior', a class considered 'for fun' where he comes from, is perceived in this world as a good class?! That the most difficult dungeons have never been conquered?! In other words\\u2026 he will be able to enjoy this world as if it were a new game! Determined to show everyone what a good class is, he brings together classmates, allows his reserved childhood friend to become an Alchemist, transforms a selfish Princess into a Saint\\u2026 Now that he has gathered powerful classes around from him, he is ready to conquer the dungeons!<br><br>\\n\\n(Source: TO BOOKS press release)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx209224-VLggLckiqkCc.jpg\",\"color\":\"#5dbbe4\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/dankatsu_anime\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":196653,\"title\":{\"romaji\":\"Game Sekai Tensei <Dankatsu>: Gamer wa [Dungeon Shuukatsu no Susume] wo <Hajime kara> Play Suru\",\"native\":\"\\u30b2\\u30fc\\u30e0\\u4e16\\u754c\\u8ee2\\u751f\\u3008\\u30c0\\u30f3\\u6d3b\\u3009\\uff5e\\u30b2\\u30fc\\u30de\\u30fc\\u306f\\u3010\\u30c0\\u30f3\\u30b8\\u30e7\\u30f3\\u5c31\\u6d3b\\u306e\\u30b9\\u30b9\\u30e1\\u3011\\u3092\\u3008\\u306f\\u3058\\u3081\\u304b\\u3089\\u3009\\u30d7\\u30ec\\u30a4\\u3059\\u308b\\uff5e\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/196653\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":188875,\"title\":{\"romaji\":\"Game Sekai Tensei <Dankatsu>: Gamer wa [Dungeon Shuukatsu no Susume] wo <Hajime kara> Play Suru @COMIC\",\"native\":\"\\u30b2\\u30fc\\u30e0\\u4e16\\u754c\\u8ee2\\u751f\\u3008\\u30c0\\u30f3\\u6d3b\\u3009\\uff5e\\u30b2\\u30fc\\u30de\\u30fc\\u306f\\u3010\\u30c0\\u30f3\\u30b8\\u30e7\\u30f3\\u5c31\\u6d3b\\u306e\\u30b9\\u30b9\\u30e1\\u3011\\u3092\\u3008\\u306f\\u3058\\u3081\\u304b\\u3089\\u3009\\u30d7\\u30ec\\u30a4\\u3059\\u308b\\uff5e@COMIC\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/188875\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":195496,\"idMal\":61973,\"title\":{\"romaji\":\"GATE 2: Jieitai Kano Umi nite, Kaku Tatakaeri\",\"native\":\"GATE \\uff12 \\u2015\\u81ea\\u885b\\u968a \\u5f7c\\u306e\\u6d77\\u306b\\u3066\\u3001\\u65af\\u304f\\u6226\\u3048\\u308a\\u2015\",\"english\":null},\"startDate\":{\"year\":2027,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Action\",\"Adventure\",\"Drama\",\"Fantasy\"],\"synonyms\":[\"Gate Season 2: Thus the JSDF Fought in Their Seas!\",\"GATE SEASON2 \\u81ea\\u885b\\u968a \\u5f7c\\u306e\\u6d77\\u306b\\u3066\\u3001\\u65af\\u304f\\u6226\\u3048\\u308a\",\"GATE 2: Tides of Conflict\"],\"duration\":null,\"popularity\":7123,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#GATE2\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/195496\",\"description\":\"Thanks to the efforts of Lieutenant Yoji Itami (now Lieutenant First Class) of the Japan Ground Self-Defense Force, the once-closed \\\"GATE\\\" has safely reopened. The Japanese government, determined to maintain exclusive control over the \\\"GATE\\\", continues mobilizing the Self-Defense Forces for political and topographical surveys to build a peaceful relationship with the inhabitants of the Special Region. Captain First Class Edajima Goro of the Japan Maritime Self-Defense Force (JMSDF) and his subordinate, Petty Officer Second Class Tokushima Hajime, a skilled former chef, were conducting such diplomatic and investigative missions, traveling across the various nations of the Special Region.<br><br>\\n\\nHowever, one day, their assignment suddenly escalates when they're tasked with a special mission to rescue an American journalist kidnapped on an island in the Special Region's Blue Sea.<br><br>\\n\\nImmediately boarding the JMSDF Oyashio-class submarine Kitashio, they set sail into the ocean of another world, discovering the area around the Blue Sea engulfed in turmoil, with archipelago nations and pirates battling fiercely for dominance.<br><br>\\n\\n(Source: GATE 2: Tides of Conflict Site)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx195496-HX1gSeijZp8I.jpg\",\"color\":\"#5dc9f1\"},\"trailer\":{\"id\":\"2P40hX1vK1E\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/2P40hX1vK1E\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/gate_animeEN\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/gate2.oshi.co\\/r1a\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\