d99\\u96e8\\u3068\\u30bb\\u30ec\\u30ca\\u30fc\\u30c7\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/207692\",\"description\":\"On rainy days, Hina has dreams about her younger self playing with a mysterious boy in a garden she's never seen before\\u2014until, by chance, she stumbles upon the place. There's a young man there, Takaaki, who mistakes Hina for his fianc\\u00e9e Hinako. He whisks her back to what he thinks is her home, where Hina's doppelganger is waiting, and Hina realizes this isn't the Tokyo she left behind but Japan in the year 1907! Is this all a dream or something much stranger?<br><br>\\n(Source: Kodansha USA)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx207692-0OjYSxl722u7.jpg\",\"color\":\"#f1ae43\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/namidaame-anime.com\\/\"}],\"rankings\":[{\"rank\":21,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":104233,\"title\":{\"romaji\":\"Namida Ame to Serenade\",\"native\":\"\\u6d99\\u96e8\\u3068\\u30bb\\u30ec\\u30ca\\u30fc\\u30c7\",\"english\":\"Rainy Day Serenade\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/104233\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":154122,\"idMal\":null,\"title\":{\"romaji\":\"Nano List\",\"native\":\"\\ub098\\ub178\\ub9ac\\uc2a4\\ud2b8\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Action\",\"Romance\",\"Sci-Fi\"],\"synonyms\":[],\"duration\":24,\"popularity\":334,\"episodes\":12,\"source\":\"MANGA\",\"countryOfOrigin\":\"KR\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/154122\",\"description\":\"Milo lives in a world where interacting with androids is completely normal. And now, he lives with TWO androids built by his sister. How safe is he living with androids who have deadly strength? Why did his sister gift him a \\\"bodyguard android?\\\" Well, he's about to find out the hard way.\\n<br><br>\\n(Source: WEBTOONS)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b154122-2ANItPevH1o4.png\",\"color\":\"#f19343\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7288,\"name\":\"Gale\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7288\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":97615,\"title\":{\"romaji\":\"Nano List\",\"native\":\"\\ub098\\ub178\\ub9ac\\uc2a4\\ud2b8\",\"english\":\"Nano List\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/97615\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":162561,\"idMal\":54688,\"title\":{\"romaji\":\"NARUTO (Shinsaku Anime)\",\"native\":\"NARUTO -\\u30ca\\u30eb\\u30c8- (\\u65b0\\u4f5c\\u30a2\\u30cb\\u30e1)\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[\"Action\",\"Adventure\",\"Comedy\"],\"synonyms\":[],\"duration\":null,\"popularity\":13913,\"episodes\":4,\"source\":null,\"countryOfOrigin\":\"JP\",\"hashtag\":\"#NARUTO #\\u30ca\\u30eb\\u30c8 #NARUTO20th\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/162561\",\"description\":\"The official website for the <i>NARUTO<\\/i> anime franchise announced a new anime project: to air four \\\"brand-new\\\" episodes to celebrate the TV anime's 20th anniversary back in 2022. <br><br>(Source: Anime News Network, edited) <br><br>\\n<i>Note: Title, format, and relations are provisio