TERNATIVE\",\"node\":{\"id\":146120,\"title\":{\"romaji\":\"Kyoufu Collector\",\"native\":\"\\u6050\\u6016\\u30b3\\u30ec\\u30af\\u30bf\\u30fc\",\"english\":\"Horror Collector\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/146120\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":206949,\"idMal\":63382,\"title\":{\"romaji\":\"Kyouran Reijou Nia Liston\",\"native\":\"\\u51f6\\u4e71\\u4ee4\\u5b22\\u30cb\\u30a2\\u30fb\\u30ea\\u30b9\\u30c8\\u30f3\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":10,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"FALL\",\"format\":\"TV\",\"genres\":[\"Fantasy\"],\"synonyms\":[\"Nia Liston: The Merciless Maiden\"],\"duration\":null,\"popularity\":2408,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u51f6\\u4e71\\u4ee4\\u5b22\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206949\",\"description\":\"A great hero lies undefeated on her deathbed, regretting that she never found a foe who could take her down. She never intended to meet her fate anywhere other than on the battlefield, and her peaceful demise has her wishing desperately that things could have been different... But when she suddenly comes to in the body of the young, frail Nia Liston, she\\u2019s got an all-new fight ahead of her. Nia is a sickly child, meaning she has a long way to go before she\\u2019s in fighting form. Now that she\\u2019s been given a second shot at life, however, she\\u2019s determined to get what she wants. She\\u2019s going to live\\u2014and die\\u2014for battle this time! Make way for the Merciless Maiden!<br>\\n<br>\\n(Source: J-Novel Club)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206949-OwIba0xC2YQm.jpg\",\"color\":\"#86281a\"},\"trailer\":{\"id\":\"HKdiA5mNb_A\",\"site\":\"youtube\",\"thumbnail\":\"ht