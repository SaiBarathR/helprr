elations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":138522,\"title\":{\"romaji\":\"Thunderbolt Fantasy: Touriken Yuuki 4\",\"native\":\"Thunderbolt Fantasy \\u6771\\u96e2\\u528d\\u904a\\u7d004\",\"english\":\"Thunderbolt Fantasy Sword Seekers 4\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/138522\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":185901,\"idMal\":61040,\"title\":{\"romaji\":\"TRUST\",\"native\":\"TRUST\",\"english\":null},\"startDate\":{\"year\":2025,\"month\":3,\"day\":9},\"endDate\":{\"year\":2025,\"month\":3,\"day\":9},\"status\":\"FINISHED\",\"season\":\"WINTER\",\"format\":\"ONA\",\"genres\":[\"Mystery\",\"Sci-Fi\"],\"synonyms\":[\"Young Animator Training Project 2025\",\"Anime no Tane 2025\"],\"duration\":10,\"popularity\":196,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/185901\",\"description\":\"In the near future, as technology takes another leap forward, humanity becomes increasingly immersed in the metaverse. However, with this digital evolution comes a surge in cybercrime. To counter it more effectively, metaverse operators have begun equipping AI with advanced investigative capabilities.\\n<br><br>\\nViolet, an artificial intelligence designed for interrogations, is assigned a new task: to question a young woman named Mia.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx185901-iRIID6SJ3ugs.png\",\"color\":null},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/animenotane.jp\\/2025-02-20\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6067,\"name\":\"POLYGON PICTURES\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6067\"}]},\"relations\":{\"edges\":[{\"relationType\":\"OTHER\",\"node\":{\"id\":185898,\"title\":{\"romaji\":\"Galaxy Apartment\\u2605Cosmo Hills\",\"native\":\"\\u30ae\\u30e3\\u30e9\\u30af\\u30b7\\u30fc\\u30a2\\u30d1\\u30fc\\u30c8\\u2605\\u30b3\\u30b9\\u30e2\\u30d2\\u30eb\\u30ba\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/185898\"}},{\"relationType\":\"OTHER\",\"node\":{\"id\":185900,\"title\":{\"romaji\":\"Hoshi no Kodomo to Hajimari no Ki\",\"native\":\"\\u661f\\u306e\\u5b50\\u3069\\u3082\\u3068\\u306f\\u3058\\u307e\\u308a\\u306e\\u6a39\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/185900\"}},{\"relationType\":\"OTHER\",\"node\":{\"id\":185903,\"title\":{\"romaji\":\"DIVE IN!\",\"native\":\"DIVE IN!\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/185903\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":154392,\"idMal\":52967,\"title\":{\"romaji\":\"Versailles no Bara Movie\",\"native\":\"\\u5287\\u5834\\u7248 \\u30d9\\u30eb\\u30b5\\u30a4\\u30e6\\u306e\\u3070\\u3089\",\"english\":\"The Rose of Versailles\"},\"startDate\":{\"year\":2025,\"month\":1,\"day\":31},\"endDate\":{\"year\":2025,\"month\":1,\"day\":31},\"status\":\"FINISHED\",\"season\":\"WINTER\",\"format\":\"MOVIE\",\"genres\":[\"Adventure\",\"Drama\",\"Romance\"],\"synonyms\":[\"The Rose of Versailles Movie\",\"R\\u00f3\\u017ca Wersalu\",\"Rosa de Versalhes\"],\"duration\":113,\"popularity\":10678,\"episodes\":1,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30d9\\u30eb\\u30b5\\u30a4\\u30e6\\u306e\\u3070\\u3089 #\\u30d9\\u30eb\\u3070\\u3089 #\\u30d9\\u30eb\\u3070\\u3089\\u6620\\u753b\",\"averageScore\":61,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/154392\",\"description\":\"Movie project commemorating the 50th anniversary of the <i>Versailles no Bara<\\/i> manga's publication. <br><br>\\nHoping to unite their countries with an alliance, The Empress of Austria arranges her daughter, the delightful yet spoiled Marie Antoinette, to marry the crown prince of France, Louis XVI. Upon arriving in Versailles, the Austrian princess meets Oscar Francois de Jarjayes, Captain of the Royal Guards\\u2014a seemingly dashing young man\\u2014but to Antoinette's astonishment, he is in fact a woman!\\n <br><br>\\nThe youngest daughter of a noble family with a prominent lack of a male heir, Oscar was raised as a boy to continue the family's military legacy. Suffocated by the rigid rules associated with her new position and longing for companionship, Antoinette immediately takes a liking to this intriguing young woman, and wastes no time befriending her. However, as the childish new queen foolishly abuses her power, Oscar is conflicted between maintaining her loyalty to the royal family and addressing the growing concern of poverty among the common people.\\n <br><br>\\nRecalling the events of the French Revolution, Versailles no Bara depicts the struggles of two women unjustly burdened by family expectations. Yet, despite being forced to deny their identities at the expense of personal happiness, they march on to become key players in the annals of history.\\n <br><br>\\n(Source: MAL Rewrite)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/154392-Bxh3SvquRjkZ.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx154392-I35rrWRu9KlY.jpg\",\"color\":\"#e4ae50\"},\"trailer\":{\"id\":\"ymTlXvI9AEU\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/ymTlXvI9AEU\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/verbara-movie.jp\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/verbara_movie\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/@verbara-movie\"},{\"site\":\"Netflix\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/10-rVGPom8RCiwH.png\",\"color\":\"#E50914\",\"url\":\"https:\\/\\/www.netflix.com\\/title\\/81177638\"}],\"rankings\":[{\"rank\":37,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":13,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":569,\"name\":\"MAPPA\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/569\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":30660,\"title\":{\"romaji\":\"Versailles no Bara\",\"native\":\"\\u30d9\\u30eb\\u30b5\\u30a4\\u30e6\\u306e\\u3070\\u3089\",\"english\":\"The Rose of Versailles\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/30660\"}},{\"relationType\":\"PARENT\",\"node\":{\"id\":338,\"title\":{\"romaji\":\"Versailles no Bara\",\"native\":\"\\u30d9\\u30eb\\u30b5\\u30a4\\u30e6\\u306e\\u3070\\u3089\",\"english\":\"Lady Oscar: The Rose of Versailles\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/338\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":185088,\"idMal\":60410,\"title\":{\"romaji\":\"Yami Shibai 14\",\"native\":\"\\u95c7\\u829d\\u5c45 \\u5341\\u56db\\u671f\",\"english\":\"Theatre of Darkness: Yamishibai 14\"},\"startDate\":{\"year\":2025,\"month\":1,\"day\":6},\"endDate\":{\"year\":2025,\"month\":4,\"day\":7},\"status\":\"FINISHED\",\"season\":\"WINTER\",\"format\":\"TV_SHORT\",\"genres\":[\"Horror\",\"Supernatural\"],\"synonyms\":[\"Yamishibai: Japanese Ghost Stories Fourteenth Season\"],\"duration\":4,\"popularity\":1555,\"episodes\":13,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u95c7\\u829d\\u5c45\",\"averageScore\":53,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/185088\",\"description\":\"Fourteenth season of <i>Yami Shibai<\\/i>.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx185088-pY2KxbG0KIoO.jpg\",\"co