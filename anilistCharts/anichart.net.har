            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":false,\"total\":1},\"media\":[{\"id\":203490,\"idMal\":63061,\"title\":{\"romaji\":\"Uchi no Otouto-domo ga Sumimasen\",\"native\":\"\\u3046\\u3061\\u306e\\u5f1f\\u3069\\u3082\\u304c\\u3059\\u307f\\u307e\\u305b\\u3093\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":4},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Romance\",\"Slice of Life\"],\"synonyms\":[],\"duration\":null,\"popularity\":1295,\"episodes\":24,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3046\\u3061\\u5f1f\\u30a2\\u30cb\\u30e1\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/203490\",\"description\":\"The manga centers on high school student Ito Hazui. During her spring break at the end of her first year of high school, Ito's mother remarries, and Ito moves to live with her new family, becoming Ito Narita. Upon arriving at her new house, Ito is shocked to learn she now has four younger step-brothers. Ito tries her hardest to get along with all of the new members of her family, but the eldest brother Gen is a bit cold to her. However, under his aloof facade, he occasionally shows his kindness.\\n<BR><BR>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx203490-D6GOKA0OWblB.jpg\",\"color\":\"#fef150\"},\"trailer\":{\"id\":\"Mqbl2gcETcc\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/Mqbl2gcETcc\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/uchioto-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/uchioto_anime\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6075,\"name\":\"Lay-duce\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6075\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":117345,\"title\":{\"romaji\":\"Uchi no Otoutodomo ga Sumimasen\",\"native\":\"\\u3046\\u3061\\u306e\\u5f1f\\u3068\\u3099\\u3082\\u304b\\u3099\\u3059\\u307f\\u307e\\u305b\\u3093\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/117345\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":1,\"airingAt\":1783090800},{\"episode\":2,\"airingAt\":1783695600}]}}]}}}"
