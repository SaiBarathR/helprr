/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/120-Q60x0hPKE19B.png\",\"color\":\"#E6162D\",\"url\":\"https:\\/\\/weibo.com\\/u\\/7657514159\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6162,\"name\":\"Foch\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6162\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":127189,\"title\":{\"romaji\":\"Aoao Dai Bu\",\"native\":\"\\u6556\\u6556\\u5f85\\u6355\",\"english\":\"Dragon In Distress\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/127189\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":21430,\"idMal\":null,\"title\":{\"romaji\":\"Aoki Uru\",\"native\":\"\\u84bc\\u304d\\u30a6\\u30eb\",\"english\":\"Uru in Blue\"},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Sci-Fi\"],\"synonyms\":[],\"duration\":null,\"popularity\":2527,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/21430\",\"description\":\"In March 1992, Gainax had begun planning and production of an anime movie called Aoki Uru, which was to be a sequel to Royal Space Force: The Wings of Honneamise set 50 years later, which, like Oritsu, would follow a group of fighter pilots.<br>\\n<br>\\nProduction would eventually cease in July 1993: a full-length anime movie was just beyond Gainax's financial ability; many of its core businesses were shutting down or producing minimal amounts of money.<br>\\n<br>\\nAt the 2013 Tokyo Anime Fair, Gainax announced that they are finally producing the Aoki Uru film with Honneamise veterans Hiroyuki Yamaga as the director and screenwriter and Yoshiyuki Sadamoto as the character designer but without Hideaki Anno's involvement in the project.<br>\\n<br>\\nIn 2018, it was announced that a studio Gaina (formerly Fukushima Gainax, a branch of Gainax that had been acquired by the conglomerate company Kinoshita Group) had taken over the production of Aoki Uru, and was aiming for a 2022 theatrical release. However, in late December 2022 with no release, Yamaga was still described as \\\"currently working\\\" on the project.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx21430-mhkUrXK54xE7.png\",\"color\":\"#863528\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6122,\"name\":\"Gaina\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6122\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":1034,\"title\":{\"romaji\":\"Ouritsu Uchuugun: Honneamise no Tsubasa\",\"native\":\"\\u738b\\u7acb\\u5b87\\u5b99\\u8ecd \\u30aa\\u30cd\\u30a2\\u30df\\u30b9\\u306e\\u7ffc\",\"english\":\"Royal Space Force: The Wings of Honn\\u00eaamise\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/1034\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":122513,\"idMal\":49567,\"title\":{\"romaji\":\"AWM Jixian Juji\",\"native\":\"AWM\\u6781\\u9650\\u72d9\\u51fb\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Romance\"],\"synonyms\":[\"AWM PUBG Mobile\",\"AWM\\u7edd\\u5730\\u6c42\\u751f\"],\"duration\":null,\"popularity\":1037,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/122513\",\"description\":null,\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx122513-vtojNd5W7EIE.jpg\",\"color\":\"#e45dbb\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Weibo\",\"icon\":\"https:\\/\\/s4.anilist.co\\/f