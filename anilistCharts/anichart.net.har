NGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30e1\\u30c0\\u30ea\\u30b9\\u30c8 #medalist\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206298\",\"description\":\"Sequel to <i>Medalist 2nd Season.<\\/i>\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206298-JlZmS2os2PQL.png\",\"color\":\"#f15d78\"},\"trailer\":{\"id\":\"C8uDLOYMM5s\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/C8uDLOYMM5s\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/medalist-pr.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/medalist_PR\"}],\"rankings\":[{\"rank\":3,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":118371,\"title\":{\"romaji\":\"Medalist\",\"native\":\"\\u30e1\\u30c0\\u30ea\\u30b9\\u30c8\",\"english\":\"Medalist\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/118371\"}},{\"relationType\":\"PREQUEL\",\"node\":{\"id\":189275,\"title\":{\"romaji\":\"Medalist 2nd Season\",\"native\":\"\\u30e1\\u30c0\\u30ea\\u30b9\\u30c8 \\u7b2c2\\u671f\",\"english\":\"Medalist Season 2\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/189275\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":129265,\"idMal\":null,\"title\":{\"romaji\":\"Meng Shen Yudao Ai\",\"native\":\"\\u68a6\\u795e\\u9047\\u5230\\u7231\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Romance\"],\"synonyms\":[\"Oniros Fall in Love\"],\"duration\":null,\"popularity\":143,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/129265\",\"description\":\"In Si Ling's family, there is a saying that if you kiss your soulmate, you will be able to enter each other's dream. One day, Si Ling unexpectedly met the An family's young master, An Yunxiu, and accidentally gave him her first kiss. Who would have thought that Si Ling was the first girl who was able to touch An Yunxiu? It was a fate that was already set, and nobody can break it.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx129265-fwxQ7yIoBviC.png\",\"color\":\"#5dbbe4\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":135184,\"title\":{\"romaji\":\"Meng Shen Yu Dao Ai\",\"native\":\"\\u68a6\\u795e\\u9047\\u5230\\u7231\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/135184\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":141920,\"idMal\":null,\"title\":{\"romaji\":\"Miaoshou Xiandan\",\"native\":\"\\u5999\\u624b\\u4ed9\\u4e39\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\",\"Romance\",\"Supernatural\"],\"synonyms\":[],\"duration\":null,\"popularity\":142,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/141920\",\"description\":\"After the death of her adoptive family at the hands of cultivator bandits, Xie Xi Gu sets out to become a cultivator herself. The world of cultivation is a cutthroat one, biased towards those with inate talent, fortunate families, and a lot of money. What Xie Xi lacks in those three qualities, she makes up for effort... and an absurd amount of strength!\\n\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b141920-7gb1eeoDJIeS.png\",\"color\":\"#f1ae35\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":101680,\"title\":{\"romaji\":\"Miaoshou Xiandan\",\"native\":\"\\u5999\\u624b\\u4ed9\\u4e39\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/101680\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":129253,\"idMal\":48874,\"title\":{\"romaji\":\"Ming Wang Huan Shi Lu\",\"native\":\"\\u660e\\u738b\\u5e7b\\u4e16\\u5f55\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Drama\",\"Romance\",\"Supernatural\"],\"synonyms\":[\"\\u56fd\\u5bb6\\u4e00\\u7ea7\\u6ce8\\u518c\\u9a71\\u9b54\\u5e08\\u4e0a\\u5c97\\u57f9\\u8bad\\u901a\\u77e5\"],\"duration\":null,\"popularity\":236,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/129253\",\"description\":null,\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx129253-PQypjzRy3CJj.jpg\",\"color\":\"#1a4393\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6481,\"name\":\"CG Year\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6481\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":114720,\"idMal\":41919,\"title\":{\"romaji\":\"Mo Duzhe\",\"native\":\"\\u9ed8\\u8bfb\\u8005\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Drama\",\"Mystery\"],\"synonyms\":[\"Silent Reader\",\"Silent Reading\"],\"duration\":20,\"popularity\":2040,\"episodes\":12,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/114720\",\"description\":\"Childhood, upbringing, family background, social relations, traumatic experiences...<br><br>We keep reviewing and seeking out the motives of criminals, exploring the subtlest emotions driving them. It\\u2019s not to put ourselves in their shoes and sympathize, or even forgive them; it\\u2019s not to find some reasons to exculpate their crimes; it\\u2019s not to kneel down before the so-called \\\"complexity of human nature\\\"; nor to introspect social conflicts, much less to alienate ourselves into monsters.<br><br>We just want to have a fair trial \\u2013 for ourselves and for those who still have hope for the world.\\n\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx114720-QlE20q1EMniH.jpg\",\"color\":null},\"trailer\":{\"id\":\"XBVIvvkFEP8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/XBVIvvkFEP8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Tencent Video\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/121-BQIBl0q1Eh9w.png\",\"color\":\"#2FA3F9\",\"url\":\"https:\\/\\/v.qq.com\\/detail\\/m\\/m30q8dgfz7qy1sm.html\"},{\"site\":\"Weibo\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/120-Q60x0hPKE19B.png\",\"color\":\"#E6162D\",\"url\":\"https:\\/\\/www.weibo.com\\/u\\/7220095185\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6176,\"name\":\"L\\u00b2 Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6176\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\