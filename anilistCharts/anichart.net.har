\"#00A1D6\",\"url\":\"https:\\/\\/www.bilibili.com\\/bangumi\\/media\\/md28235394\\/\"},{\"site\":\"Weibo\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/120-Q60x0hPKE19B.png\",\"color\":\"#E6162D\",\"url\":\"https:\\/\\/weibo.com\\/u\\/7721084644\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6948,\"name\":\"Studio Mindo\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6948\"},{\"id\":7059,\"name\":\"APEX VISION\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7059\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":158987,\"idMal\":null,\"title\":{\"romaji\":\"Jing Wei Wu Jian\",\"native\":\"\\u6cfe\\u6e2d\\u65e0\\u95f4\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Drama\",\"Mystery\",\"Psychological\",\"Romance\"],\"synonyms\":[\"Two Adamant Hearts\",\"Jing Wei Qing Shang\",\"\\u6cfe\\u6e2d\\u60c5\\u6b87\"],\"duration\":null,\"popularity\":367,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/158987\",\"description\":\"Adapted from the JJWXC novel \\u2018Jing Wei Qing Shang\\u2019 by Qing Jun Mo Xiao\\/Please Don\\u2019t Laugh, this is a romantic story about two incredible young women.  \\n<br><br>\\nLegend says that the land was once separated by the Luo river. \\n<br><br>\\nTo the south was the agricultural Wei kingdom, and to the north, the nomadic Jing kingdom. \\n<br><br>\\nAgula, a Princess of the Jing kingdom, had to become a Prince since birth so that her loving parents could stay together. Nangong Jingnu, a Princess of the Wei kingdom, was meant to live a carefree life, but the political struggles of the court made it necessary for her to follow the footsteps of her father. \\n<br><br>\\nAfter a war turned Agula into an orphan, sh