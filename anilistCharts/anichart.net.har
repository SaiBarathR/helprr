/x.com\\/shogakukan_univ\"}],\"rankings\":[{\"rank\":10,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":5,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false},{\"rank\":6,\"type\":\"RATED\",\"season\":\"SPRING\",\"allTime\":false},{\"rank\":5,\"type\":\"POPULAR\",\"season\":\"SPRING\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7472,\"name\":\"Imagica Infos\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7472\"},{\"id\":7531,\"name\":\"Imageworks Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7531\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":208220,\"title\":{\"romaji\":\"Daikenja Riddle no Jikan Gyakkou\",\"native\":\"\\u5927\\u8ce2\\u8005\\u30ea\\u30c9\\u30eb\\u306e\\u6642\\u9593\\u9006\\u884c\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/208220\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":8,\"airingAt\":1779281700},{\"episode\":9,\"airingAt\":1779886500}]}},{\"id\":208352,\"idMal\":63572,\"title\":{\"romaji\":\"Dandelion\",\"native\":\"\\u3060\\u3093\\u3067\\u3089\\u3044\\u304a\\u3093\",\"english\":\"Dandelion\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":16},\"endDate\":{\"year\":2026,\"month\":4,\"day\":16},\"status\":\"FINISHED\",\"season\":\"SPRING\",\"format\":\"ONA\",\"genres\":[\"Action\",\"Comedy\",\"Supernatural\"],\"synonyms\":[\"Dente-de-Le\\u00e3o\",\"\\u041e\\u0434\\u0443\\u0432\\u0430\\u043d\\u0447\\u0438\\u043a\",\"\\u30c0\\u30f3\\u30c7\\u30e9\\u30a4\\u30aa\\u30f3\",\"Diente de Le\\u00f3n\"],\"duration\":29,\"popularity\":6674,\"episodes\":7,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3060\\u3093\\u3067\\u3089\\u3044\\u304a\\u3093 #dandelion\",\"averageScore\":72,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/208352\",\"description\":\"Dandelion follows Tetsuo Tanba and Misaki Kurogane, members of the Japanese Angel Federation\\u2019s Send-Off Department. Their job? Tracking down restless earthbound spirits and gently guiding them to the afterlife.<br><br>\\n\\nWhile other angels rush to close their cases, the 21st Division\\u2019s Dandelion Clan takes a different approach. Dandelion members Tetsuo Tanba and his leader, Misaki Kurogane, listen to each spirit\\u2019s regrets and help them resolve what\\u2019s holding them back. They even help a spirit who\\u2019s an elderly man running at full speed, desperate to escape.<br><br>\\n\\nThe angels themselves are full of surprises. Tanba\\u2019s permanent scowl and sharp tongue mask a deeply compassionate nature, while Kurogane is a formidable force \\u2014 despite her girlish appearance. She\\u2019s rumored to have laid to rest the legendary soul of Musashi Miyamoto.<br><br>\\n(Source: Netflix)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b208352-KUuXI4sVbtYV.jpg\",\"color\":\"#e4d65d\"},\"trailer\":{\"id\":\"IRe_ScY2C3s\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/IRe_ScY2C3s\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/dandelion_0914\"},{\"site\":\"Netflix\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/10-rVGPom8RCiwH.png\",\"color\":\"#E50914\",\"url\":\"https:\\/\\/netflix.com\\/title\\/81579317\"}],\"rankings\":[{\"rank\":13,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":25,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":951,\"name\":\"NAZ\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/951\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":189873,\"title\":{\"romaji\":\"Dandelion\",\"native\":\"\\u3060\\u3093\\u3067\\u3089\\u3044\\u304a\\u3093\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/189873\"}}]},\"airingS