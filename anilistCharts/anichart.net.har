6,\"title\":{\"romaji\":\"Sazae-san\",\"native\":\"\\u30b5\\u30b6\\u30a8\\u3055\\u3093\",\"english\":null},\"startDate\":{\"year\":1969,\"month\":10,\"day\":5},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"FALL\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Slice of Life\"],\"synonyms\":[\"Mrs. Sazae\"],\"duration\":24,\"popularity\":2366,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":55,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/2406\",\"description\":\"The main character is a mother named Sazae-san. She lives in a house with her husband, her kid, her siblings and her parents. The show is the ultimate family program and tends to follow traditional themes. Think of this show as the Japanese equivalent to \\\"The Partridge Family\\\" and you'll get a good feel for this show's atmosphere. Don't expect to see things like violence, swearing, kung-fu action or magical girls. The plots are more like \\\"Today, Sazae-san goes to the new mall and gets lost\\\". Such \\\"boring\\\" plotlines and the simplistic art are often a turn-off to non-Japanese audiences, but most Japanese find the show incredibly good. As a result, it continues to be one of the top ratings grabbers on TV and is one of the few anime that is considered \\\"acceptable\\\" by adults.\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/2406-ROqXxejQ5bH9.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx2406-nP8NIct9Sci3.jpg\",\"color\":\"#f1bb43\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"http:\\/\\/www.sazaesan.jp\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.fujitv.co.jp\\/sazaesan\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\