            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":true,\"total\":5000},\"media\":[{\"id\":205444,\"idMal\":63253,\"title\":{\"romaji\":\"Majo no Tabitabi Movie\",\"native\":\"\\u5287\\u5834\\u7248 \\u9b54\\u5973\\u306e\\u65c5\\u3005\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Adventure\",\"Fantasy\",\"Slice of Life\"],\"synonyms\":[\"Wandering Witch: The Journey of Elaina Movie\",\"MajoTabi\",\"\\ub9c8\\ub140\\uc758 \\uc5ec\\ud589\",\"\\u9b54\\u5973\\u4e4b\\u65c5\",\"Elainas Reise\",\"\\u0e01\\u0e32\\u0e23\\u0e40\\u0e14\\u0e34\\u0e19\\u0e17\\u0e32\\u0e07\\u0e02\\u0e2d\\u0e07\\u0e04\\u0e38\\u0e13\\u0e41\\u0e21\\u0e48\\u0e21\\u0e14\",\"\\u0421\\u0442\\u0440\\u0430\\u043d\\u0441\\u0442\\u0432\\u0443\\u044e\\u0449\\u0430\\u044f \\u0432\\u0435\\u0434\\u044c\\u043c\\u0430\"],\"duration\":null,\"popularity\":3998,\"episodes\":1,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u9b54\\u5973\\u306e\\u65c5\\u3005\\u306f\\u3044\\u3044\\u305e\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/205444\",\"description\":\"Sequel movie to <i>Majo no Tabitabi<\\/i>.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx205444-dhVRPyVQaHrr.png\",\"color\":null},\"trailer\":{\"id\":\"vhqJ5SSjJZU\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/vhqJ5SSjJZU\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/majotabi.jp\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/majotabi_PR\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":112609,\"title\":{\"romaji\":\"Majo no Tabitabi\",\"native\":\"\\u9b54\\u5973\\u306e\\u65c5\\u3005\",\"english\":\"Wandering Witch: The Journey of Elaina\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/112609\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":98741,\"title\":{\"romaji\":\"Majo no Tabitabi\",\"native\":\"\\u9b54\\u5973\\u306e\\u65c5\\u3005\",\"english\":\"Wandering Witch: The Journey of Elaina\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/98741\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":105913,\"title\":{\"romaji\":\"Majo no Tabitabi\",\"native\":\"\\u9b54\\u5973\\u306e\\u65c5\\u3005\",\"english\":\"Wandering Witch: The Journey of Elaina\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/105913\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":205372,\"idMal\":62685,\"title\":{\"romaji\":\"Mang Huang Ji (2026)\",\"native\":\"\\u83bd\\u8352\\u7eaa (2026)\",\"english\":\"Mang Wasteland Period\"},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\"],\"synonyms\":[\"The Desolate Era\"],\"duration\":null,\"popularity\":114,\"episodes\":26,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/205372\",\"description\":\"Fate had never been kind to Ji Ning. Wracked by illnesses and infirm his entire life on Earth, Ning knew early on that he would die as a teenager. What he didn\\u2019t know was that there really was such a thing as life after death, and that the universe was a far larger place than he thought. A lucky twist of fate (one of the few in Ning\\u2019s life) meant that Ning was reborn into a world of Immortals and monsters, of Ki Refiners and powerful Fiendgods, a world where Dynasties lasted for millions of years. A world which is both greater and yet also smaller than he ever could imagine. He would have the opportunity to join them, and in this life, Ning swore to himself, he would never let himself be weak again! The Era he was born into was a Desolate one, but Ning would make it his era.\\n<br><br>\\n(Source: Novel Update)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx205372-9fVFyRIsra1X.jpg\",\"color\":\"#ff501a\"},\"trailer\":{\"id\":\"Cmps4G9bDzk\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/Cmps4G9bDzk\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Youku\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/126-QUuKXK3ri4c2.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/v.youku.com\\/v_show\\/id_XNjQzMjQ1NTkxNg==.html?s=ebbc3479514f44aeb699\"},{\"site\":\"Youku TV\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.youku.tv\\/v\\/v_show\\/id_XNjQzMzk2MjYyOA==.html?spm=a2hje.13141534.app.5~5!5~A&scm=20140719.rcmd.241952.show_effa3e6ef33341dfb3ca&s=effa3e6ef33341dfb3ca\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7116,\"name\":\"Shenman Entertainment\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7116\"}]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":102164,\"title\":{\"romaji\":\"Mang Huang Ji\",\"native\":\"\\u83bd\\u8352\\u7eaa\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/102164\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":86482,\"title\":{\"romaji\":\"Mang Huang Ji\",\"native\":\"\\u83bd\\u8352\\u7eaa\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/86482\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":129261,\"idMal\":null,\"title\":{\"romaji\":\"Mantou Riji 2\",\"native\":\"\\u9992\\u5934\\u65e5\\u8bb0 \\u7b2c\\u4e8c\\u5b63\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"