.com\\/vi\\/GlcCq4ne2lk\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/painoko_anime\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/senpaiha-otokonoko.com\\/\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@painoko_anime\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GW4HM7WP9\\/senpai-is-an-otokonoko\"}],\"rankings\":[{\"rank\":19,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":18,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":4399,\"name\":\"project No.9\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/4399\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":118570,\"title\":{\"romaji\":\"Senpai wa Otokonoko\",\"native\":\"\\u5148\\u8f29\\u306f\\u304a\\u3068\\u3053\\u306e\\u3053\",\"english\":\"Senpai is an Otokonoko\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/118570\"}},{\"relationType\":\"PREQUEL\",\"node\":{\"id\":163133,\"title\":{\"romaji\":\"Senpai wa Otokonoko\",\"native\":\"\\u5148\\u8f29\\u306f\\u304a\\u3068\\u3053\\u306e\\u3053\",\"english\":\"Senpai is an Otokonoko\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/163133\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":183412,\"idMal\":56335,\"title\":{\"romaji\":\"Shimajirou: Shimajirou to Yuuki no Uta\",\"native\":\"\\u6620\\u753b\\u3057\\u307e\\u3058\\u308d\\u3046\\u3057\\u307e\\u3058\\u308d\\u3046\\u3068 \\u3086\\u3046\\u304d\\u306e\\u3046\\u305f\",\"english\":null},\"startDate\":{\"year\":2025,\"month\":3,\"day\":14},\"endDate\":{\"year\":2025,\"month\":3,\"day\":14},\"status\":\"FINISHED\",\"season\":\"WINTER\",\"format\":\"MOVIE\",\"genres\":[\"Adventure\",\"Comedy\",\"Fantasy\"],\"synonyms\":[\"Shimajiro the Movie: Shimajiro and the Song of Courage\"],\"duration\":75,\"popularity\":81,\"episodes\":1,\"source\":\"OTHER\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u6620\\u753b\\u3057\\u307e\\u3058\\u308d\\u3046\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/183412\",\"description\":\"The story centers on Miley, a young white tiger who is offered the lead role of Captain Hat by an acting troupe. Miley has no confidence in herself, so Shimajirou comes up with a plan to encourage her. Suddenly, they are sucked into a magical bag, and must embark on an adventure in the world within the bag.\\n<br><br>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx183412-aquaVDg24IRw.png\",\"color\":\"#ffe400\"},\"trailer\":{\"id\":\"tHuf3kkqi1M\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/tHuf3kkqi1M\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/kocha.benesse.ne.jp\\/kodomo\\/open\\/movie\\/2025\\/\"}],\"rankings\":[{\"rank\":81,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":6160,\"name\":\"Shimogumi\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6160\"},{\"id\":471,\"name\":\"Shanghai Animation Film Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/471\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PARENT\",\"node\":{\"id\":18941,\"title\":{\"romaji\":\"Shimajirou no Wow!\",\"native\":\"\\u3057\\u307e\\u3058\\u308d\\u3046\\u306e\\u308f\\u304a!\",\"english\":\"Shimajiro: A Wonderful Adventure\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/18941\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":136381,\"idMal\":49363,\"title\":{\"romaji\":\"SK\\u221e Extra Part\",\"native\":\"SK\\u221e \\u30a8\\u30b9\\u30b1\\u30fc\\u30a8\\u30a4\\u30c8 EXTRA PART\",\"english\":\"SK8 the Infinity EXTRA PART\"},\"startDate\":{\"year\":2025,\"month\":1,\"day\":24},\"endDate\":{\"year\":2025,\"month\":1,\"day\":24},\"status\":\"FINISHED\",\"season\":\"WINTER\",\"format\":\"OVA\",\"genres\":[\"Action\",\"Comedy\",\"Drama\",\"Slice of Life\",\"Sports\"],\"synonyms\":[\"Sk8 the Infinity OVA\",\"SK\\u221e \\u30a8\\u30b9\\u30b1\\u30fc\\u30a8\\u30a4\\u30c8 OVA EXTRA PART\"],\"duration\":25,\"popularity\":22738,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#sk_8 #\\u30a8\\u30b9\\u30b1\\u30fc\\u30a8\\u30a4\\u30c8\",\"averageScore\":78,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/136381\",\"description\":\"Original video animation for <i>SK\\u221e (Sk8 the Infinity)<\\/i>. <br><br>\\nFour slice-of-life omnibus stories.\\n<br><br>\\n- The Rain and a Cat, Soda Ice Cream from the Convenience Store\\nOne Sunday, Reki, Langa, and Miya head out to the skatepark as usual when a squall suddenly hits them. They head back to Reki\\u2019s place and start playing Karuta, a Japanese card game they find!?\\n<br><br>\\n- Becoming Really Serious About Things\\nIn the past, Sakurayashiki and Nanjo had spent their high school days in relative obscurity. These two always had butt heads and competed, but what lies ahead for them from all this competition?\\n<br><br>\\n- Morning Routine\\nThis story unravels the mystery surrounding Ainosuke and Kikuchi\\u2019s everyday life. It closes in on their secret moments, crossovers, and a moment beyond that draws closer.\\n<br><br>\\n- Hiromi, Do Your Best!\\nShadow is an anti-hero at night, but this is his three-part slice-of-life flash story highlighting his noble and kind personality as he works hard at a flower shop during the day.\\n<br><br>\\n(Source: Aniplex USA)\\n<br><br>\\n<i>Premiered in theaters on 01\\/24\\/2025. The home video was released on 03\\/19\\/2025.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx136381-t6c5rfKjnqqd.jpg\",\"color\":\"#43aee4\"},\"trailer\":{\"id\":\"9SG3Q5BoQO8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/9SG3Q5BoQO8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/sk8_project\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/sk8-project.com\\/ova\\/\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/sk8_anime\\/\"},{\"site\":\"Facebook\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/38-JvMCwgmWvF6Z.png\",\"color\":\"#4267B2\",\"url\":\"https:\\/\\/www.facebook.com\\/sk8.anime\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/G5PHNM434\\/sk8-the-infinity\"}],\"rankings\":[{\"rank\":41,\"type\":\"RATED\",\"season\":null,\"allTime\":true},{\"rank\":2,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":2,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7585,\"name\":\"bones film\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7585\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PARENT\",\"node\":{\"id\":124153,\"title\":{\"romaji\":\"SK\\u221e\",\"native\":\"SK\\u221e \\u30a8\\u30b9\\u30b1\\u30fc\\u30a8\\u30a4\\u30c8\",\"english\":\"SK8 the Infinity\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/124153\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":189893,\"idMal\":60984,\"tit