lor\":\"#50aefe\"},\"trailer\":{\"id\":\"y-efbopLrYk\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/y-efbopLrYk\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/taiari-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/taiari_anime\"}],\"rankings\":[{\"rank\":19,\"type\":\"POPULAR\",\"season\":\"SUMMER\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":51,\"name\":\"diomed\\u00e9a\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/51\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":114646,\"title\":{\"romaji\":\"Tai-Ari deshita.: Ojou-sama wa Kakutou Game nante Shinai\",\"native\":\"\\u5bfe\\u3042\\u308a\\u3067\\u3057\\u305f\\u3002\\uff5e\\u304a\\u5b22\\u3055\\u307e\\u306f\\u683c\\u95d8\\u30b2\\u30fc\\u30e0\\u306a\\u3093\\u3066\\u3057\\u306a\\u3044\\uff5e\",\"english\":\"Young Ladies Don\\u2019t Play Fighting Games\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/114646\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":198709,\"idMal\":62476,\"title\":{\"romaji\":\"Tefuda ga Oume no Victoria\",\"native\":\"\\u624b\\u672d\\u304c\\u591a\\u3081\\u306e\\u30d3\\u30af\\u30c8\\u30ea\\u30a2\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Action\",\"Drama\",\"Fantasy\",\"Romance\"],\"synonyms\":[\"Victoria of Many Faces\"],\"duration\":null,\"popularity\":2418,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/198709\",\"description\":\"In an age when spies act behind the scenes in every land, Chloe spends her days successfully carrying out even the most difficult missions due to her unparalleled disguise skills and martial arts abilities. After the betrayal of her boss, she suddenly disappears\\u2014as Chloe plans to redo her life as the ordinary citizen Victoria in the neighboring kingdom of Ashberry, striving for a \\u201cnormal\\u201d life. However, Victoria's peaceful life is abruptly cut short as she begins to get involved with many people. In this new land, her experiences and abilities from her days as a spy come in far more useful than she ever expected! On the other hand, the second prince--and others--take an interest in Victoria's strength, and the shadows close in on the woman with many faces\\u2026\\n<br><br>\\n(Source: Yen Press)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx198709-KnZCqdH7fu3F.png\",\"color\":\"#35a10d\"},\"trailer\":{\"id\":\"rQnR2y6KRXg\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/rQnR2y6KRXg\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/victoria-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/tefudavictoria\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":37,\"name\":\"Studio DEEN\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/37\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":163273,\"title\":{\"romaji\":\"Tefuda ga Oume no Victoria\",\"native\":\"\\u624b\\u672d\\u304c\\u591a\\u3081\\u306e\\u30d3\\u30af\\u30c8\\u30ea\\u30a2\",\"english\":\"Victoria of Many Faces\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/163273\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":163272,\"title\":{\"romaji\":\"Tefuda ga Oume no Victoria\",\"native\":\"\\u624b\\u672d\\u304c\\u591a\\u3081\\u306e\\u30d3\\u30af\\u30c8\\u30ea\\u30a2\",\"english\":\"Victoria of Many Faces\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/163272\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":169583,\"idMal\":56735,\"title\":{\"romaji\":\"Tenkousaki no Seiso Karen na Bishoujo ga, Mukashi Danshi to Omotte Issho ni Asonda Osananajimi datta Ken\",\"native\":\"\\u8ee2\\u6821\\u5148\\u306e\\u6e05\\u695a\\u53ef\\u6190\\u306a\\u7f8e\\u5c11\\u5973\\u304c\\u3001\\u6614\\u7537\\u5b50\\u3068\\u601d\\u3063\\u3066\\u4e00\\u7dd2\\u306b\\u904a\\u3093\\u3060\\u5e7c\\u99b4\\u67d3\\u3060\\u3063\\u305f\\u4ef6\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Romance\"],\"synonyms\":[\"Tenkosaki: The Neat and Pretty Girl at My New School Is a Childhood Friend of Mine Who I Thought Was a Boy\",\"Tenbin\"],\"duration\":null,\"popularity\":4945,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3066\\u3093\\u3073\\u3093\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/169583\",\"description\":\"I met my childhood friend again, and she had become a beautiful and innocent girl.\\n<br><br>\\n\\\"It's been a while, Hayato.\\\"<br>\\n\\\"Haruki, is it?\\\"\\n<br><br>\\nIn the past, I used to play in the mud with my childhood friend in the countryside, and when I saw him again, there was no trace of the bratty young man I thought he was back then. Only in front of Hayato, she threw away the coat she was wearing and reacted in the same crass way she did back then. The distance between you and me has not changed.\\n<br><br>\\n(Source: Shousetsuka ni Narou, translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx169583-z8hCPfE2rzVX.jpg\",\"color\":\"#5dbbf1\"},\"trailer\":{\"id\":\"UTsFnJgDJz8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/UTsFnJgDJz8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/tenbin_anime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/tenbin-anime.asmik-ace.co.jp\\/\"}],\"rankings\":[{\"rank\":28,\"type\":\"POPULAR\",\"season\":\"SUMMER\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":4399,\"name\":\"project No.9\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/4399\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":130804,\"title\":{\"romaji\":\"Tenkousaki no Seiso Karen na Bishoujo ga, Mukashi Danshi to Omotte Issho ni Asonda Osananajimi datta Ken\",\"native\":\"\\u8ee2\\u6821\\u5148\\u306e\\u6e05\\u695a\\u53ef\\u6190\\u306a\\u7f8e\\u5c11\\u5973\\u304c\\u3001\\u6614\\u7537\\u5b50\\u3068\\u601d\\u3063\\u3066\\u4e00\\u7dd2\\u306b\\u904a\\u3093\\u3060\\u5e7c\\u99b4\\u67d3\\u3060\\u3063\\u305f\\u4ef6\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/130804\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":139732,\"title\":{\"romaji\":\"Tenkousaki no Seiso Karen na Bishoujo ga, Mukashi Danshi to Omotte Issho ni Asonda Osananajimi datta Ken\",\"native\":\"\\u8ee2\\u6821\\u5148\\u306e\\u6e05\\u695a\\u53ef\\u6190\\u306a\\u7f8e\\u5c11\\u5973\\u304c\\u3001\\u6614\\u7537\\u5b50\\u3068\\u601d\\u3063\\u3066\\u4e00\\u7dd2\\u306b\\u904a\\u3093\\u3060\\u5e7c\\u99b4\\u67d3\\u3060\\u3063\\u305f\\u4ef6\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/139732\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":190569,\"idMal\":61483,\"title\":{\"romaji\":\"Tenmaku no Jaadugar\",\"native\":\"\\u5929\\u5e55\\u306e\\u30b8\\u30e3\\u30fc\\u30c9\\u30a5\\u30fc\\u30ac\\u30eb\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Drama\"],\"synonyms\":[\"A Witch's Life in Mongol\",\"Jaadugar: A Witch in Mongolia\"],\"duration\":null,\"popularity\":9715,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#Jaadugar #AWitchInMongolia\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/190569\",\"description\":\"Eight centuries ago, in the latter days of the Islamic golden age, a young girl arrived in the Khwarazmian city of Tus. She was a slave. But she learned. \\n<BR><BR>\\nEight centuries ago, the Mongols blazed across the map, swept Khwarazm into the ash heap of history, and took all they desired from the ruins. They took the girl who learned. \\n<BR><BR>\\nSo begins the true story of how a \\u201cwitch,\\u201d wielding knowledge as her only weapon, came to hold the greatest empire the world has ever known in the palm of her hand\\u2026\\n<BR><BR>\\n(Source: Yen Press)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/190569-fQrApHKs9PIz.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx190569-OUDdG2zckpML.png\",\"color\":\"#e4935d\"},\"trailer\":{\"id\":\"AA9GMXHQhR8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/AA9GMXHQhR8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/anime_jaadugar\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/Jaadugar_global\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/anime-jaadugar.com\\/\"}],\"rankings\":[{\"rank\":17,\"type\":\"