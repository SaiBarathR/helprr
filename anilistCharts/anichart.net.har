            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":true,\"total\":5000},\"media\":[{\"id\":194393,\"idMal\":61839,\"title\":{\"romaji\":\"Aishiteru Game wo Owarasetai\",\"native\":\"\\u611b\\u3057\\u3066\\u308b\\u30b2\\u30fc\\u30e0\\u3092\\u7d42\\u308f\\u3089\\u305b\\u305f\\u3044\",\"english\":\"I Want to End this Love Game\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":14},\"endDate\":{\"year\":2026,\"month\":6,\"day\":30},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Romance\"],\"synonyms\":[],\"duration\":24,\"popularity\":31996,\"episodes\":12,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u611b\\u3057\\u3066\\u308b\\u30b2\\u30fc\\u30e0\\u3092\\u7d42\\u308f\\u3089\\u305b\\u305f\\u3044\",\"averageScore\":71,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/194393\",\"description\":\"Childhood friends Yukiya and Miku share everything\\u2026except their feelings. Ever since sixth grade, they\\u2019ve played a \\u201clove game\\u201d: they take turns saying \\u201cI love you\\u201d and whoever gets flustered first loses. Now in high school, their hearts are closer than ever\\u2014but will they finally find the courage to confess?\\n<br><br>\\n(Source: Crunchyroll)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/194393-FmUDMgF0apUJ.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx194393-0H9yYABu6y0i.jpg\",\"color\":\"#43aef1\"},\"trailer\":{\"id\":\"oGJrnyjDbsA\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/oGJrnyjDbsA\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.aishiteru-game.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/aishiterugame\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GT00371779\"}],\"rankings\":[{\"rank\":42,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":38,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false},{\"rank\":22,\"type\":\"RATED\",\"season\":\"SPRING\",\"allTime\":false},{\"rank\":17,\"type\":\"POPULAR\",\"season\":\"SPRING\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":6126,\"name\":\"Felix Film\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6126\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":143031,\"title\":{\"romaji\":\"Aishiteru Game wo Owarasetai\",\"native\":\"\\u611b\\u3057\\u3066\\u308b\\u30b2\\u30fc\\u30e0\\u3092\\u7d42\\u308f\\u3089\\u305b\\u305f\\u3044\",\"english\":\"I Want to End This Love Game\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/143031\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":6,\"airingAt\":1779199200},{\"episode\":7,\"airingAt\":1779804000}]}},{\"id\":196935,\"idMal\":62164,\"title\":{\"romaji\":\"Akane-banashi\",\"native\":\"\\u3042\\u304b\\u306d\\u567a\",\"english\":\"Akane-banashi\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":4},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Drama\"],\"synonyms\":[\"\\u0e2d\\u0e32\\u0e04\\u0e32\\u0e40\\u0e19\\u0e30 \\u0e1e\\u0e25\\u0e34\\u0e01\\u0e15\\u0e33\\u0e19\\u0e32\\u0e19\\u0e27\\u0e07\\u0e01\\u0e32\\u0e23\\u0e23\\u0e32\\u0e04\\u0e38\\u0e42\\u0e01\\u0e30\",\"\\u0421\\u043a\\u0430\\u0437\\u0430\\u043d\\u0438\\u0435 \\u043e\\u0431 \\u0410\\u043a\\u0430\\u043d\\u044d\"],\"duration\":25,\"popularity\":29730,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3042\\u304b\\u306d\\u567a\",\"averageScore\":76,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/196935\",\"description\":\"<i>\\\"With only your voice and body\\u2014master the art.\\\"<\\/i><br><br>\\n\\nAkane Ousaki, captivated since childhood by the magical performances of her father, Shinta Arakawa, witnesses a shocking incident during his decisive performance for promotion to shin\\u2019uchi (master rank).<br><br>\\n\\nSix years later, now a high school student, she sets her sights on becoming a shin\\u2019uchi herself\\u2014pushing forward in the highly competitive world of rakugo.<br><br>\\nA passionate and authentic rakugo drama begins now!\\n<br><br>\\n(Source: TV Asahi, edited)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/196935-tl3sNMXDMfaQ.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx196935-RnLWBsEvNp8M.jpg\",\"color\":\"#e4785d\"},\"trailer\":{\"id\":\"PZJAOQ-7iJ8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/PZJAOQ-7iJ8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/akanebanashi_PR\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/akane-banashi.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/akanebanashi_en\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/@akane-banashi_global\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@akanebanashi_en\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co