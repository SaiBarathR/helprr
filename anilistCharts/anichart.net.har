":{\"nodes\":[{\"id\":7794,\"name\":\"JUVENAGE\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7794\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":147074,\"title\":{\"romaji\":\"Kami no Niwatsuki Kusunoki-tei\",\"native\":\"\\u795e\\u306e\\u5ead\\u4ed8\\u304d\\u6960\\u6728\\u90b8\",\"english\":\"Kusunoki's Garden of Gods\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/147074\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":180080,\"title\":{\"romaji\":\"Kami no Niwatsuki Kusunoki-tei\",\"native\":\"\\u795e\\u306e\\u5ead\\u4ed8\\u304d\\u6960\\u6728\\u90b8 \",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/180080\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":7,\"airingAt\":1778949000},{\"episode\":8,\"airingAt\":1779553800}]}},{\"id\":202508,\"idMal\":62981,\"title\":{\"romaji\":\"Kami no Shizuku\",\"native\":\"\\u795e\\u306e\\u96eb\",\"english\":\"The Drops of God\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":10},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Drama\",\"Mystery\",\"Slice of Life\"],\"synonyms\":[\"Les Gouttes de Dieu\",\"\\uc2e0\\uc758\\ubb3c\\ubc29\\uc6b8\",\"\\u0e2a\\u0e37\\u0e1a\\u0e21\\u0e23\\u0e14\\u0e01\\u0e02\\u0e49\\u0e32\\u0e21\\u0e0a\\u0e32\\u0e15\\u0e34 \\u0e2b\\u0e22\\u0e32\\u0e14\\u0e40\\u0e17\\u0e27\\u0e30\"],\"duration\":24,\"popularity\":3919,\"episodes\":24,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u795e\\u306e\\u96eb #TheDropsofGod\",\"averageScore\":54,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/202508\",\"description\":\"World-renowned wine critic Yutaka Kanzaki has passed away, leaving behind a wine collection worth over 12 billion yen. His will states that his collection will be given to the one who can identify the origin and year of twelve wines he\\u2019s chosen, the \\u201cTwelve Apostles\\u201d, and one that\\u2019s superior even to them, <i>\\u201cThe Drops of God\\u201d. <\\/i><br><br>\\nCompeting for the prize are Yutaka\\u2019s son, Shizuku, who received a world-class education in wine but rebelled against his father and has never drank a drop, and Issei Tomine, a young charismatic wine critic whom Yutaka had recently adopted as his son. <br><br>\\nWhat is wine? What is a parent and a child? What is life?<br>\\nThe complex and fragrant battle surrounding the legendary <i>\\u201dDrops of God\\u201d<\\/i> is about to begin\\u2026 <br><br>\\n(Source: Pony Canyon)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/202508-K276v0truxE0.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx202508-dk6LEyevJYUY.jpg\",\"color\":\"#e44386\"},\"trailer\":{\"id\":\"Oz5EkYVJbBc\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/Oz5EkYVJbBc\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/@dropsofgodanime\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/dropsofgodAnime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/dropsofgod-anime.com\\/\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GT00371872\\/the-drops-of-god\"},{\"site\":\"iQ\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/122-EPBJ2E0oPt5C.png\",\"color\":\"#00CC36\",\"url\":\"https:\\/\\/www.iq.com\\/album\\/2f82gh1fg1l\"}],\"rankings\":[{\"rank\":95,\"type\":\"RATED\",\"season\":null,\"allTime\":false}],\"studios\":{\