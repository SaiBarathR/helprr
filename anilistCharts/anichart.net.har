ag\":\" #\\u3055\\u3088\\u306a\\u3089\\u30e9\\u30e9 #GoodbyeLara #\\u3055\\u3088\\u30e9\\u30e9\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/177637\",\"description\":\"<i> All because of \\\"love\\\"<\\/i><br><br>\\n\\nAnnounced and revealed at Anime Central 2024's \\\"Kinema Citrus Sweet 16: My Happy Marriage and What's New\\\" panel, this anime follows a mermaid who makes a forbidden wish to be loved by a human. Following her death, she is reborn 200 years later into modern-day Japan in Lake Biwa, where she learns to adjust in a human world. <br><br>\\n\\n(Source: Anime News Network, edited)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/177637-2Ok4Pq0SpvHp.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx177637-8onaQWqKW1C3.jpg\",\"color\":\"#5daee4\"},\"trailer\":{\"id\":\"-FVOUh7_obU\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/-FVOUh7_obU\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/goodbyelara.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/Goodbye_Lara\"}],\"rankings\":[{\"rank\":21,\"type\":\"POPULAR\",\"season\":\"SUMMER\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":290,\"name\":\"Kinema Citrus\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/290\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":210031,\"idMal\":63832,\"title\":{\"romaji\":\"Seihantai na Kimi to Boku 2nd Season\",\"native\":\"\\u6b63\\u53cd\\u5bfe\\u306a\\u541b\\u3068\\u50d5 \\u7b2c2\\u671f\",\"english\":\"You and I Are Polar Opposites Season 2\"},\"startDate\":{\"year\":2026,\"month\":7,\"day\":5},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_Y