railer\":{\"id\":\"5bqBtR_flBE\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/5bqBtR_flBE\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/playlist?list=PLBakWosU0sfgYqINupphZSY07LJsnGfd-\"},{\"site\":\"Bilibili\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/45-6JAD1SYYCHI2.png\",\"color\":\"#00A1D6\",\"url\":\"https:\\/\\/www.bilibili.com\\/bangumi\\/media\\/md23775579\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/playlist?list=PLBakWosU0sfgq3jbizQuKt6mj0SfpGk1R\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6323,\"name\":\"Paper Plane Animation Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6323\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":125443,\"title\":{\"romaji\":\"Myohan Insaeng\",\"native\":\"\\ubb18\\ud55c \\uc778\\uc0dd\",\"english\":\"Just for a Meowment\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/125443\"}}]}}},{\"id\":409420,\"episode\":1335,\"airingAt\":1778916600,\"media\":{\"id\":966,\"idMal\":966,\"title\":{\"romaji\":\"Crayon Shin-chan\",\"native\":\"\\u30af\\u30ec\\u30e8\\u30f3\\u3057\\u3093\\u3061\\u3083\\u3093\",\"english\":\"Shin Chan\"},\"startDate\":{\"year\":1992,\"month\":4,\"day\":13},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Ecchi\",\"Slice of Life\"],\"synonyms\":[],\"duration\":21,\"popularity\":18817,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":77,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/966\",\"description\":\"Crayon Shin-chan follows the wacky antics and adventures of five-year-old Shinnosuke \\\"Shin\\\" Nohara and his parents, neighbors, and friends and is set in Kasukabe, Saitama Prefecture, Japan.<br><br>\\nMany of the jokes in the series stem from Shin-chan's occasionally weird, unnatural and inappropriate use of language, as well as from his inappropriate behavior. A typical gag involves Shin-chan confounding his parents by using the wrong phrase for the occasion; for example, saying \\\"Welcome back!\\\" instead of \\\"I am back!\\\" when he comes home.<br><br>\\nDuring the beginning of the series, the TV show was mostly based on the storyline in the original manga. As the show progressed, more and more episodes became anime-original.\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/966-J5CwLLTBs4OO.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b966-QUCdKAk4ls9J.jpg\",\"color\":\"#e4e428\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.tv-asahi.co.jp\\/shinchan\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.shinchan-app.jp\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/crayon_official\"}],\"rankings\":[{\"rank\":2,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":3,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":247,\"name\":\"Shin-Ei Animation\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/247\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":32435,\"title\":{\"romaji\":\"Crayon Shin-chan\",\"native\":\"\\u30af\\u30ec\\u30e8\\u30f3\\u3057\\u3093\\u3061\\u3083\\u3093\",\"english\":\"Crayon Shinchan\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/32435\"}},{\"rel