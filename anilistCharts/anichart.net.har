            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":true,\"total\":5000},\"media\":[{\"id\":141924,\"idMal\":null,\"title\":{\"romaji\":\"Suo Long\",\"native\":\"\\u9501\\u9f99\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Comedy\",\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":69,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/141924\",\"description\":null,\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b141924-ZldDMb9a3nWJ.png\",\"color\":\"#f1ae5d\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":156631,\"idMal\":53529,\"title\":{\"romaji\":\"Sword Art Online (Original Movie)\",\"native\":\"\\u30bd\\u30fc\\u30c9\\u30a2\\u30fc\\u30c8\\u30fb\\u30aa\\u30f3\\u30e9\\u30a4\\u30f3 (\\u30aa\\u30ea\\u30b8\\u30ca\\u30eb\\u5287\\u5834\\u7248)\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":10246,\"episodes\":null,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#sao_anime\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/156631\",\"description\":\"A new original movie for <i>Sword Art Online<\\/i>.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx156631-lUclkm7H6f9o.png\",\"color\":null},\"trailer\":{\"id\":\"mwhGSYeIJBs\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/mwhGSYeIJBs\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/sao_anime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.swordart-online.net\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"PARENT\",\"node\":{\"id\":11757,\"title\":{\"romaji\":\"Sword Art Online\",\"native\":\"\\u30bd\\u30fc\\u30c9\\u30a2\\u30fc\\u30c8\\u30fb\\u30aa\\u30f3\\u30e9\\u30a4\\u30f3\",\"english\":\"Sword Art Online\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/11757\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":199435,\"idMal\":null,\"title\":{\"romaji\":\"Taibai Jinxing Youdian Fan\",\"native\":\"\\u592a\\u767d\\u91d1\\u661f\\u6709\\u70b9\\u70e6\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Slice of Life\"],\"synonyms\":[\"The Annoyance of the Gods\"],\"duration\":null,\"popularity\":43,\"episodes\":null,\"source\":\"NOVEL\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/199435\",\"description\":\"We follow the daily life of Li Chang Geng, an immortal who has to deal with high-pressure situations at work as best he can.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx199435-DfuKsa5fEKhe.png\",\"color\":\"#1aaeff\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":168247,\"idMal\":null,\"title\":{\"romaji\":\"Tao Yu Mo Shi Zhi Shu\",\"native\":\"\\u6843\\u4e0e\\u672b\\u4e16\\u4e4b\\u4e66\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[\"Last Word of the World\",\"Peach and the Book of the Last Days\",\"Of Machines and Beasts\"],\"duration\":null,\"popularity\":314,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/168247\",\"description\":\"Sparked by scientific experiments gone awry, civilization had collapsed in the future world and most regions had regressed to the tribal level. The incident also caused irreversible mutations in people, splitting them into two species: those with mechanical integrations called Machines, and those who had animal genes, Beast Spirits. As a Machine, Black-Eyed Rock roamed the path between the two races, in search of the answers to this world and fighting for everyone\\u2019s beliefs!\\n<br><br>\\n(Source: Webcomics)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx168247-Ph6aj4e2y52o.png\",\"color\":\"#f1a143\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Tencent Video\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/121-BQIBl0q1Eh9w.png\",\"color\":\"#2FA3F9\",\"url\":\"https:\\/\\/v.qq.com\\/x\\/cover\\/mzc00200a519upd.html\"},{\"site\":\"Weibo\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/120-Q60x0hPKE19B.png\",\"color\":\"#E6162D\",\"url\":\"https:\\/\\/weibo.com\\/u\\/7231308554\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7448,\"name\":\"Fun Media\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7448