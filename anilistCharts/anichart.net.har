            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":false,\"total\":13},\"media\":[{\"id\":197543,\"idMal\":62270,\"title\":{\"romaji\":\"BanG Dream! Ave Mujica: prima aurora\",\"native\":\"BanG Dream! Ave Mujica prima aurora\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":2026,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"FALL\",\"format\":\"MOVIE\",\"genres\":[\"Drama\",\"Music\"],\"synonyms\":[\"Ave Mujica - prima aurora - Movie\",\"BanG Dream! Ave Mujica Movie\"],\"duration\":null,\"popularity\":1871,\"episodes\":1,\"source\":\"OTHER\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#AveMujica \",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/197543\",\"description\":\"<i>Note: Relations are provisional and subject to change when more info is announced.<\\/i>\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx197543-xBfqUnKFxzMK.png\",\"color\":\"#f186a1\"},\"trailer\":{\"id\":\"nWlLg8jRnUY\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/nWlLg8jRnUY\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/avemujica-movie.bang-dream.com\\/\"}],\"rankings\":[{\"rank\":29,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"OTHER\",\"node\":{\"id\":169295,\"title\":{\"romaji\":\"BanG Dream! Ave Mujica\",\"native\":\"BanG Dream! Ave Mujica\",\"english\":\"Ave Mujica - The Die is Cast -\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/169295\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":207327,\"idMal\":63423,\"title\":{\"romaji\":\"Doko yori mo Tooi Basho ni Iru Kimi e\",\"native\":\"\\u3069\\u3053\\u3088\\u308a\\u3082\\u9060\\u3044\\u5834\\u6240\\u306b\\u3044\\u308b\\u541b\\u3078\",\"english\":\"To You in the Beyond\"},\"startDate\":{\"year\":2026,\"month\":10,\"day\":9},\"endDate\":{\"year\":2026,\"month\":10,\"day\":9},\"status\":\"NOT_YET_RELEASED\",\"season\":\"FALL\",\"format\":\"MOVIE\",\"genres\":[\"Mystery\",\"Romance\"],\"synonyms\":[\"\\u3069\\u3053\\u304d\\u307f\",\"DokoKimi\"],\"duration\":null,\"popularity\":2995,\"episodes\":1,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3069\\u3053\\u304d\\u307f\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/207327\",\"description\":\"The  story centers on a boy named Kazuki Tsukigase, who transfers to a high school on a remote island to get away from anyone who knows him. Kazuki finds out that there is an inlet on the island where people are rumored to disappear. Exploring the inlet, he encounters an unconscious girl. When she comes to after Kazuki takes her to the clinic, she is unable to give out anything about her identity except that she is named Nao, is 16 years old, and whispers the year \\\"1974.\\\"<br><br>\\n(Source: Anime News Network, edited) \",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx207327-FFWbqs7iMFKJ.jpg\",\"color\":\"#c9e4f1\"},\"trailer\":{\"id\":\"fdFjlaZvix8\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/fdFjlaZvix8\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/dokokimi_movie\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/sh-anime.shochiku.co.jp\\/dokokimi-movie\\/\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@dokokimi_movie\"}],\"rankings\":[{\"rank\":21,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":73,\"name\":\"TMS Entertainment\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/73\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":114869,\"title\":{\"romaji\":\"Doko yori mo Tooi Basho ni Iru Kimi e\",\"native\":\"\\u3069\\u3053\\u3088\\u308a\\u3082\\u9060\\u3044\\u5834\\u6240\\u306b\\u3044\\u308b\\u541b\\u3078\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/114869\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":207426,\"title\":{\"romaji\":\"Doko yori mo Tooi Basho ni Iru Kimi e\",\"native\":\"\\u3069\\u3053\\u3088\\u308a\\u3082\\u9060\\u3044\\u5834\\u6240\\u306b\\u3044\\u308b\\u541b\\u3078\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/207426\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":1,\"airingAt\":1791471600}]}},{\"id\":202390,\"idMal\":39168,\"title\":{\"romaji\":\"Girls und Panzer: Saishuushou 5\",\"native\":\"\\u30ac\\u30fc\\u30eb\\u30ba\\uff06\\u30d1\\u30f3\\u30c4\\u30a1\\u30fc \\u6700\\u7d42\\u7ae0 \\u7b2c5\\u8a71\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":10,\"day\":9},\"endDate\":{\"year\":2026,\"month\":10,\"day\":9},\"status\":\"NOT_YET_RELEASED\",\"season\":\"FALL\",\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Sports\"],\"synonyms\":[\"Girls und Panzer das Finale 5\",\"Girls und Panzer das Finale - Part 5\"],\"duration\":null,\"popularity\":2184,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#garupan\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/202390\",\"description\":\"The fifth film in the six-part <i>Girls und Panzer: Saishuushou<\\/i> film series.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx202390-HCkyjItNJ4Go.png\",\"color\":\"#6b931a\"},\"trailer\":{\"id\":\"-x5s8vNLeio\",\"site\":\"youtube\",\"thumbnail\"