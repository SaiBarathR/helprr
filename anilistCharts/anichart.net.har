genres\":[\"Adventure\",\"Drama\",\"Psychological\",\"Slice of Life\"],\"synonyms\":[\"\\u30cb\\u30fc\\u30c7\\u30a3\\u30ac\\u30fc\\u30eb \\u30aa\\u30fc\\u30d0\\u30fc\\u30c9\\u30fc\\u30ba\",\"NEEDY STREAMER OVERLOAD\",\"NEEDY GIRL OVERDOSE -OVERTURE-\"],\"duration\":25,\"popularity\":29705,\"episodes\":13,\"source\":\"VIDEO_GAME\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30cb\\u30c7\\u30a3\\u30ac\",\"averageScore\":68,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/202102\",\"description\":\"OMGkawaiiAngel, affectionately known as \\\"KAngel\\\", is the top streamer girl with 10 million subscribers, and not a day goes by without seeing her in action. Whether online, on TV, or at a live show, she is always surrounded by her cheering fans.\\n<br><br>\\nStriving to catch up with KAngel's popularity is a three-girl streaming unit called Karamazov.\\n<br><br>\\nAnd far removed from the world of these streamers is Kache, a girl who lives with her freeloader boyfriend while working at a theme cafe.\\n<br><br>\\nThe story of the \\\"Internet Angel\\\" who captivated the world, woven by a girl who shines like a star and girls who reach for that brilliance, and the story of \\\"you\\\" on the other side of the screen, begins here.\\n<br><br>\\n(Source: Official Site)\\n<br><br>\\n<i>Note: Prior to broadcasting, \\\"NEEDY GIRL OVERDOSE -OVERTURE-\\\" \\u2014 a theatrical pre-screening of the first 3 episodes rearranged and edited together\\u2014 debuted in Japan on March 6, 2026.<\\/i>\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/202102-RBgWbaATyuDt.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx202102-7qDmTI7eT5xF.png\",\"color\":\"#c950f1\"},\"trailer\":{\"id\":\"dxiVApAjPDg\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/dxiVApAjPDg\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\