S.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/kyoukai_melody\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":189638,\"title\":{\"romaji\":\"Kyoukai no Melody\",\"native\":\"\\u5883\\u754c\\u306e\\u30e1\\u30ed\\u30c7\\u30a3\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/189638\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":100050,\"idMal\":36252,\"title\":{\"romaji\":\"LibraryCross\\u221e\",\"native\":\"LibraryCross\\u221e\",\"english\":\"Library Cross Infinite\"},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"TV\",\"genres\":[],\"synonyms\":[],\"duration\":null,\"popularity\":373,\"episodes\":null,\"source\":\"VIDEO_GAME\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/100050\",\"description\":\"Based on Otomate's puzzle role-playing game.\\n<br><br>\\nA medical student named Shiina and nine male partners are trapped in a certain dimensional realm with many ancient texts and an enormous mysterious clock. Together, they must find a way to escape by uncovering clues before the clock strikes \\\"13.\\\"\\n<br><br>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/100050-iyLeXYqEh6V5.jpg\",\"color\":null},\"trailer\":{\"id\":\"8tA8kfppUWU\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/8tA8kfppUWU\\/hqdefault.jpg\"},\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":188889,\"idMal\":61301,\"title\":{\"romaji\":\"Ma no Monotachi wa Kuwadateru\",\"native\":\"\\u9b54\\u306e\\u3082\\u306e\\u305f\\u3061\\u306f\\u4f01\\u3066\\u308b\",\"e