":\"Saber Works\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7524\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":182309,\"title\":{\"romaji\":\"Grand Blue Season 2\",\"native\":\"\\u3050\\u3089\\u3093\\u3076\\u308b Season 2\",\"english\":\"Grand Blue Dreaming Season 2\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/182309\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":87395,\"title\":{\"romaji\":\"Grand Blue\",\"native\":\"\\u3050\\u3089\\u3093\\u3076\\u308b\",\"english\":\"Grand Blue Dreaming\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/87395\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":196017,\"idMal\":62051,\"title\":{\"romaji\":\"Grow Up Show: Himawari no Circus-dan\",\"native\":\"\\u30b0\\u30ed\\u30a6\\u30a2\\u30c3\\u30d7\\u30b7\\u30e7\\u30a6 \\uff5e\\u3072\\u307e\\u308f\\u308a\\u306e\\u30b5\\u30fc\\u30ab\\u30b9\\u56e3\\uff5e\",\"english\":\"GROW UP SHOW -Sunflower Circus-\"},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[],\"synonyms\":[],\"duration\":null,\"popularity\":1352,\"episodes\":null,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30b0\\u30ed\\u30a6\\u30a2\\u30c3\\u30d7\\u30b7\\u30e7\\u30a6\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/196017\",\"description\":\"The anime's story is set in the late 1950s and early 1960s, during the height of Japan's economic boom, when the circus is a major form of entertainment. Different circus troupes travel throughout Japan to perform and compete for a chance to participate in the world-renowned festival called \\\"Circus Collection.\\\" One troupe called the \\\"Sunflower Circus,\\\" led by its ringmaster Maria, travels around Japan to perform, despite struggling with financial difficulties. However, they meet a circus prodigy named Mizuka Tsurumaki. This is the story of a one-of-a-kind circus show of young girls with big dreams.<br><br>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx196017-XSvNENgfXQmX.jpg\",\"color\":\"#e4c928\"},\"trailer\":{\"id\":\"PAneuhZLHzU\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/PAneuhZLHzU\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/growupshow.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/growupshow\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":561,\"name\":\"A-1 Pictures\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/561\"},{\"id\":7682,\"name\":\"Psyde Kick Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7682\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":199066,\"idMal\":62535,\"title\":{\"romaji\":\"Hanaori-san wa Tensei Shite mo Kenka ga Shitai\",\"native\":\"\\u82b1\\u7e54\\u3055\\u3093\\u306f\\u8ee2\\u751f\\u3057\\u3066\\u3082\\u55a7\\u5629\\u304c\\u3057\\u305f\\u3044\",\"english\":\"Hanaori-san Still Wants to Fight in the Next Life\"},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Romance\",\"Supernatural\"],\"synonyms\":[\"Hanaori-san Wants to Have A Fight Even If She Reincarnates\"],\"duration\":null,\"popularity\":2390,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30a2\\u30cb\\u30e1\\u82b1\\u7e54\\u3055\\u3093 #\\u82b1\\u7e54\\u3055\\u3093\\u306f\\u8ee2\\u751f\\u3057\\u3066\\u3082\\u55a7\\u5629\\u304c\\u3057\\u305f\\u3044\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/199066\",\"description\":\"Ryuusei Narukami spends his days cooped up in his room playing video games, but hides a secret past as an evil dark lord from a fantasy world reincarnated into our world. He has a fateful encounter with the belligerent Hanaori Meteor, the hero from Ryuusei's world who defeated him, now reincarnated as a high school girl.<br><br>\\n(Source: Anime News Network, edited)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx199066-o0aQNC5lcxFr.jpg\",\"color\":\"#43bbe4\"},\"trailer\":{\"id\":\"UXgbofdm2vQ\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/UXgbofdm2vQ\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/hanaori_anime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/hanaorisan-anime.com\\/\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":839,\"name\":\"LIDENFILMS\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/839\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":138239,\"title\":{\"romaji\":\"Hanaori-san wa Tensei Shite mo Kenka ga Shitai\",\"native\":\"\\u82b1\\u7e54\\u3055\\u3093\\u306f\\u8ee2\\u751f\\u3057\\u3066\\u3082\\u55a7\\u5629\\u304c\\u3057\\u305f\\u3044\",\"english\":\"Hanaori-san Still Wants to Fight in the Next Life\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/138239\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":209983,\"idMal\":63817,\"title\":{\"romaji\":\"Hell Mode: Yarikomizuki no Gamer wa Hai Settei no Isekai de Musou suru 2nd Season\",\"native\":\"\\u30d8\\u30eb\\u30e2\\u3