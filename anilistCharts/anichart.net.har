\\u9078\\u3093\\u3067\\u3044\\u3089\\u308c\\u307e\\u305b\\u3093~ \\u7b2c\\u4e09\\u90e8 \\u300c\\u9818\\u5730\\u306b\\u672c\\u3092\\u5e83\\u3052\\u3088\\u3046!\\u300d\",\"english\":\"Ascendance of a Bookworm ~I'll do anything to become a librarian!~ Part 3 Let's spread books through the duchy!\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/110805\"}}]}}},{\"id\":413256,\"episode\":6,\"airingAt\":1779033600,\"media\":{\"id\":202523,\"idMal\":62983,\"title\":{\"romaji\":\"Marika-chan no Koukando wa Bukkowareteiru\",\"native\":\"\\u8309\\u8389\\u82b1\\u3061\\u3083\\u3093\\u306e\\u597d\\u611f\\u5ea6\\u306f\\u3076\\u3063\\u58ca\\u308c\\u3066\\u3044\\u308b\",\"english\":\"Marika's Love Meter Malfunction\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":6},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV_SHORT\",\"genres\":[\"Comedy\",\"Drama\",\"Ecchi\",\"Romance\",\"Supernatural\"],\"synonyms\":[],\"duration\":6,\"popularity\":10349,\"episodes\":8,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u8309\\u8389\\u82b1\\u3061\\u3083\\u3093\\u306e\\u597d\\u611f\\u5ea6\\u306f\\u3076\\u3063\\u58ca\\u308c\\u3066\\u3044\\u308b\",\"averageScore\":49,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/202523\",\"description\":\"Confessing to my childhood friend Marika was impossible for someone as unpopular as me. So, I did what any desperate boy would do\\u2014I wished upon a shooting star! When I woke up, that dream had come true?! I could see a love meter for people, just like in a love simulation game. Once I realized this was real and not a dream I went straight to see Marika. Her love meter was so low it had broken and practically fallen all the way to hell! If she hated me so much why was she so nice?! Is this how she really felt or...?!\\n<br><br>\\n(Source: Coolmic)\\n<br><br>\\n<i>Note: Episode 1 received an advanced distribution on AnimeFesta on March 13th, 2026. The start date reflects the start of the regular series broadcasting.<\\/i>\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx202523-NHeyiypiPnGP.jpg\",\"color\":\"#e44378\"},\"trailer\":{\"id\":\"Ohd23eSaOaw\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/Ohd23eSaOaw\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/marikowa_off\\/\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/marikowa.af-original.com\"},{\"site\":\"OceanVeil\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/249-CFCxdC7MiNX3.png\",\"color\":\"#00D0D3\",\"url\":\"https:\\/\\/oceanveil.net\\/anime_titles\\/398\"},{\"site\":\"OceanVeil\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/249-CFCxdC7MiNX3.png\",\"color\":\"#00D0D3\",\"url\":\"https:\\/\\/oceanveil.net\\/anime_titles\\/399\"}],\"rankings\":[{\"rank\":6,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":1,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false},{\"rank\":4,\"type\":\"RATED\",\"season\":\"SPRING\",\"allTime\":false},{\"rank\":1,\"type\":\"POPULAR\",\"season\":\"SPRING\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7575,\"name\":\"studio LEO\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7575\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":188743,\"title\":{\"romaji\":\"Marika-chan no Koukando wa Bukkowareteiru\",\"native\":\"\\u8309\\u8389\\u82b1\\u3061\\u3083\\u3093\\u306e\\u597d\\u611f\\u5ea6\\u306f\\u3076\\u3063\\u58ca\\u308c\\u3066\\u3044\\u308b\",\"english\":\"Marika's Love Meter Malfunction\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/188743\"}}]}}},{\"id\":413293,\"episode\":32,\"airingAt\":1778756400,\"media\":{\"id\":19