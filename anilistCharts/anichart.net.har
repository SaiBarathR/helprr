al\":null,\"title\":{\"romaji\":\"Tou Xing Jiuyue Tian\",\"native\":\"\\u5077\\u661f\\u4e5d\\u6708\\u5929\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\",\"Romance\"],\"synonyms\":[\"Star-Stealing Girl\"],\"duration\":null,\"popularity\":159,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/141863\",\"description\":\"It's a journey filled with love and dreams. When girl next door Jiu Yue is revealed to be a notorious thief, a series of mysterious events surrounding the ancient Silan Kingdom start to occur. Love and friendship, justice and evil, power and forgiveness. How should our heroine choose her journey?\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx141863-81tTkRVoe9Ev.png\",\"color\":\"#fec928\"},\"trailer\":{\"id\":\"aWBhhTE7UYQ\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/aWBhhTE7UYQ\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Bilibili\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/45-6JAD1SYYCHI2.png\",\"color\":\"#00A1D6\",\"url\":\"https:\\/\\/www.bilibili.com\\/bangumi\\/media\\/md28235359\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7047,\"name\":\"Shenfan Animation\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7047\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":134193,\"title\":{\"romaji\":\"Tou Xing Jiuyue Tian\",\"native\":\"\\u5077\\u661f\\u4e5d\\u6708\\u5929\",\"english\":\"Star-Stealing Girl\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/134193\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":146608,\"idMal\":55359,\"title\":{\"romaji\":\"Tsurubami-Iro no Nagiko-tachi\",\"native\":\"\\u3064\\u308b\\u3070\\u307f\\u8272\\u306e\\u306a\\u304e\\u5b50\\u305f\\u3061\",\"english\":null},\"startDate\":{\"year\":2027,\"month\":null,\"day\":null},\"endDate\":{\"year\":2027,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[],\"synonyms\":[\"The Mourning Children: Nagiko and the Girls Wearing Tsurubami Black\"],\"duration\":137,\"popularity\":1321,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3064\\u308b\\u3070\\u307f\\u8272\\u306e\\u306a\\u304e\\u5b50\\u305f\\u3061\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/146608\",\"description\":\"The film follows Kyoto during the Heian period(the 10th century) in Japan. \\n<br><br>\\nTens of thousands dead, gutters filled with corpses, children abandoned in the mountains, and groups of wild dogs vigilantly watching outside the city.\\n<br><br>\\nThe elegant image of the Heian period has been shown in many literary and artistic works. However, Katabuchi's new work takes us back to Kyoto a thousand years ago, when the city was shrouded in darkness due to repeated epidemics of plague.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx146608-5FxdbWw1AHz7.png\",\"color\":null},\"trailer\":{\"id\":\"UG6xuAAKvmY\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/UG6xuAAKvmY\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/tsurubami.contrail.tokyo\\/\"}],\"rankings\":[{\"rank\":6,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7128,\"name\":\"Contrail\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7128\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":129264,\"idMal\":null,\"title\":{\"romaji\":\"Tuan Nei Jinzhi Lianai\",\"native\":\"\\u56e2\\u5185\\u7981\\u6b62\\u604b\\u7231\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Comedy\",\"Music\",\"Romance\"],\"synonyms\":[\"Be Idol Or Be Lover\"],\"duration\":null,\"popularity\":210,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/129264\",\"description\":\"Teenage girl Xia Shicheng entered the boy group Zebra dressed as a man. After her debut, she quickly became popular, and she also grabbed the limelight of the leading star Gu Lan. And just as the popularity of the male group was soaring, Xia Shicheng found herself being targeted, her true gender was hovering wildly on the verge of exposure.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx129264-Q7PdLhoXVpi9.png\",\"color\":\"#e41a5d\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":150971,\"title\":{\"romaji\":\"Tuan Nei Jinzhi Lianai\",\"native\":\"\\u56e2\\u5185\\u7981\\u6b62\\u604b\\u7231\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/150971\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":206193,\"idMal\":62786,\"title\":{\"romaji\":\"Tuer Ni Wudile Xiashan Qu Ba\",\"native\":\"\\u5f92\\u513f\\u4f60\\u65e0\\u654c\\u4e86\\u4e0b\\u5c71\\u53bb\\u5427\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Fantasy\"],\"synonyms\":[\"Return of the Invincible Heir\"],\"duration\":null,\"popularity\":34,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206193\",\"description\":\"The Ye family was suddenly massacred\\u2014Ye Beichen's parents and brothers were slaughtered, and he himself was ruthlessly thrown into the moat, clinging to life by a thread. Rescued by his senior sister, he was taken to Kunlun Mountain, where he spent five grueling years mastering martial arts. Five years later, he returned in full force, armed with the peerless skills taught by 99 invincible masters. Back in the mortal world, when faced with old enemies and powerful factions, Ye Beichen showed no fear. With extraordinary martial prowess and overwhelming strength, he unleashed chaos across the city, carving a path of revenge and dominance\\u2014turning the tables and crushing all who once sought his downfall.\\n<br><br>\\n(Source: Youku, translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206193-MqADtffLsINa.jpg\",\"color\":\"#288693\"},\"trailer\":{\"id\":\"f1U_zYVSO-0\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/f1U_zYVSO-0\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Youku\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/126-QUuKXK3ri4c2.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/v.youku.com\\/v_show\\/id_XNjQ5NDYzMDgyOA\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":133862,\"idMal\":null,\"title\":{\"romaji\":\"Tun Hai\",\"native\":\"\\u541e\\u6d77\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":52,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/133862\",\"description\":null,\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx133862-aV5vC9vSOqGl.jpg\",\"color\":\"#35d6e4\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6478,\"name\":\"Soyep\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6478\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":182615,\"idMal\":null,\"title\":{\"romaji\":\"Uchuu Senkan Yamato Movie (Provisional Title)\",\"native\":\"\\u5b87\\u5b99\\u6226\\u8266\\u30e4\\u30de\\u30c8\\uff08\\u4eee\\uff09\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Adventure\",\"Drama\",\"Sci-Fi\"],\"synonyms\":[],\"duration\":null,\"popularity\":439,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/182615\",\"description\":\"At the 50th anniversary screening attended by Hideaki Anno, Yutaka Izubuchi and Ryuusuke Hikawa, it was announced that Studio Khara was granted rights to produce a new anime movie based on <i>Space Battleship Yamato<\\/i> starting in 2025. Anno revealed that his studio acquired rights for the franchise and the soundtrack and that he is now able to create a new work.<br><br>\\n<i>Note: Title and relations are provisional and subject to change.<\\/i>\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx182615-hCQdFVlj0Jlk.png\",\"color\":null},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"http:\\/\\/tfc-chara.net\\/yamato50th\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/yamato50th\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":47,\"name\":\"Studio Khara\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/47\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":63333,\"title\":{\"romaji\":\"Uchuu Senkan Yamato\",\"native\":\"\\u5b87\\u5b99\\u6226\\u8266\\u30e4\\u30de\\u30c8\",\"english\":\"Space Battleship Yamato\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/63333\"}},{\"relationType\":\"PARENT\",\"node\":{\"id\":1650,\"title\":{\"romaji\":\"Uchuu Senkan Yamato\",\"native\":\"\\u5b87\\u5b99\\u6226\\u8266\\u30e4\\u30de\\u30c8\",\"english\":\"Star Blazers: The Quest for Iscandar\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/1650\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":212105,\"idMal\":64154,\"title\":{\"romaji\":\"Umi ga Hashiru End Roll\",\"native\":\"\\u6d77\\u304c\\u8d70\\u308b\\u30a8\\u30f3\\u30c9\\u30ed\\u30fc\\u30eb\",\"english\":null},\"startDate\":{\"year\":2027,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Comedy\",\"Drama\",\"Slice of Life\"],\"synonyms\":[\"The Credits Roll Into The Sea\"],\"duration\":null,\"popularity\":1655,\"episodes\":1,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u6d77\\u304c\\u8d70\\u308b\\u30a8\\u30f3\\u30c9\\u30ed\\u30fc\\u30eb #TheCreditsRollIntoTheSea\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/212105\",\"description\":\"Umiko, a grandma, realizes that she has the same desire to make movies as university student Kai\\u2014and soon she enrolls in Kai's film school!\\n<br><br>\\n<i>\\\"It's not the movies you like\\u2026you like watching the people watching the movies.\\\"<\\/i>\\n<br><br>\\nJust what are you going to do with the rest of your life? It's the question you'll always have to answer, no matter your age. Umiko Chino is a 65-year-old retired woman in mourning for her late husband. Remembering how they used to watch films together, Umiko goes to the movie theater for the first time in years, where she meets Kai, an attractive, ambiguous young man who studies filmmaking at a nearby art school.\\n<br><br>\\nThey would seem to have nothing in common, except for this\\u2014both of them sometimes like to look more at the way the audience reacts to a movie than the movie itself. Kai believes Umiko has the same deep desire he possesses to experience how people respond to something they made\\u2026 and challenges her to stake the rest of her life discovering that thrill.\\n<br><br>\\nSoon Umiko surprises herself by enrolling in the same film school as Kai. But sailing into this new sea, she's suddenly inside the currents of her fellow students' lives, a much younger generation that she struggles to understand, driven by their own passions and their own relationships. Who's really experienced at life, and is it old age or observation that brings wisdom? And does what you're looking for change when you look with your eyes instead of through a camera lens\\u2026?\\n<br><br>\\n(Source: Dark Horse)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b212105-f5L7q8C22ga2.png\",\"color\":\"#e4d6ae\"},\"trailer\":{\"id\":\"9Nuwm1vjO_o\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/9Nuwm1vjO_o\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/umiendrollmovie\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.kyotoanimation.co.jp\\/works\\/umiendroll\\/\"}],\"rankings\":[{\"rank\":5,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":2,\"name\":\"Kyoto Animation\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/2\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":137614,\"title\":{\"romaji\":\"Umi ga Hashiru End Roll\",\"native\":\"\\u6d77\\u304c\\u8d70\\u308b\\u30a8\\u30f3\\u30c9\\u30ed\\u30fc\\u30eb\",\"english\":\"The Credits Roll into the Sea\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/137614\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":139803,\"idMal\":49983,\"title\":{\"romaji\":\"Waixingren Shi Riji\",\"native\":\"\\u5916\\u661f\\u4eba\\u89c6\\u65e5\\u8bb0\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Comedy\"],\"synonyms\":[\"Alien Observation Diary\"],\"duration\":null,\"popularity\":84,\"episodes\":null,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/139803\",\"description\":\"The president of the \\\"Astronomy Club\\\", Di Qiuren, leads the members of the club to track down aliens, but they have been unsuccessful so far. What Qiuren doesn't know is that all of the members are aliens. On one side is the alien stalker who never gives up, and on the other side are the aliens disguised as members of the astronomy club! In order to conceal their identities, the aliens try to learn and understand the behavior of earthlings. A funny school life with them and Di Qiuren is about to unfold.\\n<br><br>\\n(Source: bilibili, translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx139803-4cFCd2OBZ04s.jpg\",\"color\":\"#28e4d6\"},\"trailer\":{\"id\":\"hiNt6cPYSXE\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/hiNt6cPYSXE\\/hqdefault.jpg\"},\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6989,\"name\":\"Observatory Animation\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6989\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":199418,\"idMal\":61642,\"title\":{\"romaji\":\"Wan Ren Zhi Shang\",\"native\":\"\\u4e07\\u4eba\\u4e4b\\u4e0a\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":59,\"episodes\":14,\"source\":\"MANGA\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/199418\",\"description\":\"Yi Feng traveled to the Xianjiang Continent. Since he was born without spiritual roots, he could only survive by relying on the \\\"essential life skills\\\" given by the system. Little did he know that in the eyes of those practitioners, his strength was already at the god level, and his every move affected the entire pattern of the Xianjiang Continent. Yi Feng easily resolved many crises without knowing it, which also brought about many passionate and hilarious scenes, and brought new opportunities and choices to the people living on this continent.<br><br>\\n\\n(Source: iQIYI, Google translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx199418-461US6GGQ8lA.jpg\",\"color\":\"#febb28\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/bangumi.tv\\/subject\\/491576\"},{\"site\":\"iQIYI\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/204-VS6anqt2SaIN.png\",\"color\":\"#00CC36\",\"url\":\"https:\\/\\/www.iqiyi.com\\/v_1046hqcgjs4.html?vfrm=pcw_album_auto\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":206272,\"idMal\":61563,\"title\":{\"romaji\":\"Wan Xiang Zhi Wang\",\"native\":\"\\u4e07\\u76f8\\u4e4b\\u738b\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[\"Absolute Resonance\"],\"duration\":null,\"popularity\":76,\"episodes\":36,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206272\",\"description\":\"Luolan Mansion, one of the five major mansions of Daxia in Shenzhou Continent, has fallen into decline due to the mysterious disappearance of two mansion masters. Although the young mansion master Li Luo is extremely talented and was born with three phase palaces, he has difficulty practicing because of his natural empty phase.\\n\\nJiang Qinge, with whom he had been engaged since childhood, has a ninth-grade light phase and is extremely talented. Realizing the gap between them, Li Luo wanted to cancel the contract and break off the engagement, but was rejected by Jiang Qinge.\\n\\nOn his seventeenth birthday, Li Luo took away the secret treasure left by his parents and obtained the water light phase, but the price was that his hair turned white overnight and his life was overdrawn. If he wanted to extend his life, he had to reach the state of a marquis within five years.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206272-BwipAvbBip2p.jpg\",\"color\":\"#f1a15d\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"iQIYI\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/204-VS6anqt2SaIN.png\",\"color\":\"#00CC36\",\"url\":\"https:\\/\\/www.iqiyi.com\\/v_1lds0j9idyk.html?vfrm=pcw_album_auto&rfr=https:\\/\\/myanimelist.net\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6481,\"name\":\"CG Year\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6481\"}]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":138390,\"title\":{\"romaji\":\"Wan Xiang Zhi Wang\",\"native\":\"\\u4e07\\u76f8\\u4e4b\\u738b\",\"english\":\"Absolute Resonance\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/138390\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":168096,\"idMal\":null,\"title\":{\"romaji\":\"Wan Zu Zhi Jie\",\"native\":\"\\u4e07\\u65cf\\u4e4b\\u52ab\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":69,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/168096\",\"description\":\"Su Yu has a secret. For more than ten years, he's been having nightmares of being pursued by murderous monsters. When he became 18, he saw his own father die in battle with those monsters from his dreams. A few years later, he will become the killer of those monsters.\\n<br><br>\\n(Source: Tencent, translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx168096-jpfr0ppwmFzm.png\",\"color\":\"#f1286b\"},\"trailer\":{\"id\":\"IuaAtPaSQyk\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/IuaAtPaSQyk\\/hqdefault.jpg\"},\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6471,\"name\":\"D.ROCK-ART\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6471\"}]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":145600,\"title\":{\"romaji\":\"Wan Zu Zhi Jie\",\"native\":\"\\u4e07\\u65cf\\u4e4b\\u52ab\",\"english\":\"Tribulations of Myriad Clans\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/145600\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":206282,\"idMal\":62954,\"title\":{\"romaji\":\"Wangu Zhizun: Li Yunxiao Zhuan\",\"native\":\"\\u4e07\\u53e4\\u81f3\\u5c0a\\uff1a\\u674e\\u4e91\\u9704\\u4f20\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[],\"duration\":null,\"popularity\":42,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206282\",\"description\":\"Gu Feiyang, the third strongest warrior on the Tianwu Continent and the Martial Emperor Pojun, was bound by the world's rules, his cultivation stuck at the Nine Heavens Martial Emperor realm for many years, unable to break through. To escape this predicament, he used the affections of Qu Hongyan, the mistress of the Shenxiao Palace, to orchestrate a grand scheme, sacrificing extraterrestrial demonic energy to reincarnate and cultivate anew.\\n<br><br>\\nIn his reincarnation, he was named Li Yunxiao, a 15-year-old boy from the Tianshui Kingdom and the eldest grandson of the Li family of the Marshal's Mansion. At this time, Tianshui was beset by powerful enemies invading from the outside and princes vying for the throne from within, making the Li family, who held military power, the center of a vortex of crisis. Faced with the power struggles of everyone, Li Yunxiao stood at a higher level, calmly breaking through the impasse. He deeply understood that in this world where martial arts reign supreme, all power ultimately came from within, and his goal remained singular: to complete the scheme laid out in his previous life and build a foundation for the Divine Realm.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206282-UFlwydoqdt4D.png\",\"color\":\"#e4bb50\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6537,\"name\":\"Dancing CG Studio\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6537\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":187594,\"idMal\":null,\"title\":{\"romaji\":\"Wanmei Shijie Movie: Jiu Jie Fen Tian\",\"native\":\"\\u5b8c\\u7f8e\\u4e16\\u754c\\u5267\\u573a\\u7248 \\u4e5d\\u52ab\\u711a\\u5929\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[\"Perfect World Movie 2\",\"\\u200b\\u5b8c\\u7f8e\\u4e16\\u754c\\u5267\\u573a\\u7248 \\u7b2c\\u4e8c\\u90e8\",\"Wanmei Shijie Movie: 2\"],\"duration\":null,\"popularity\":138,\"episodes\":null,\"source\":\"NOVEL\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/187594\",\"description\":null,\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx187594-PA8vNaoxM6Wp.jpg\",\"color\":\"#28aefe\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/bangumi.tv\\/subject\\/542046\"},{\"site\":\"Tencent Video\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/121-BQIBl0q1Eh9w.png\",\"color\":\"#2FA3F9\",\"url\":\"https:\\/\\/v.qq.com\\/x\\