            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":false,\"total\":12},\"media\":[{\"id\":211711,\"idMal\":64107,\"title\":{\"romaji\":\"Boku no Hero Academia: I am a hero too\",\"native\":\"\\u50d5\\u306e\\u30d2\\u30fc\\u30ed\\u30fc\\u30a2\\u30ab\\u30c7\\u30df\\u30a2 I am a hero too\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":2026,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"SPECIAL\",\"genres\":[],\"synonyms\":[\"My Hero Academia: I am a hero too Special\"],\"duration\":null,\"popularity\":4928,\"episodes\":1,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#heroaca_a\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/211711\",\"description\":\"Following the broadcast of My Hero Academia Episode 170+1, the series' official website and accounts revealed that a new short anime adapting the \\\"I Am a Hero Too\\\" bonus chapter will tell the story of Eri as a high-schooler when it releases this summer.<br><br>\\n(Source: Crunchyroll)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx211711-Oy6R5cmGHLCL.jpg\",\"color\":\"#f1d61a\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/heroaca.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/heroaca_anime\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":204356,\"title\":{\"romaji\":\"Boku no Hero Academia No. 170+1: More\",\"native\":\"\\u50d5\\u306e\\u30d2\\u30fc\\u30ed\\u30fc\\u30a2\\u30ab\\u30c7\\u30df\\u30a2 No. 170+1 \\u300cMore\\u300d\",\"english\":\"My Hero Academia More\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/204356\"}},{\"relationType\":\"PARENT\",\"node\":{\"id\":85486,\"title\":{\"romaji\":\"Boku no Hero Academia\",\"native\":\"\\u50d5\\u306e\\u30d2\\u30fc\\u30ed\\u30fc\\u30a2\\u30ab\\u30c7\\u30df\\u30a2\",\"english\":\"My Hero Academia\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/85486\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":202717,\"idMal\":63011,\"title\":{\"romaji\":\"Chiikawa: Ningyo no Shima no Himitsu\",\"native\":\"\\u6620\\u753b\\u3061\\u3044\\u304b\\u308f \\u4eba\\u9b5a\\u306e\\u5cf6\\u306e\\u3072\\u307f\\u3064\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":24},\"endDate\":{\"year\":2026,\"month\":7,\"day\":24},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"MOVIE\",\"genres\":[\"Comedy\",\"Slice of Life\"],\"synonyms\":[\"Chiikawa the Movie: The Secret of Mermaid Island\",\"\\u3061\\u3044\\u304b\\u308f \\u30bb\\u30a4\\u30ec\\u30fc\\u30f3\\u7de8\",\"Chiikawa: Siren Arc\"],\"duration\":null,\"popularity\":1340,\"episodes\":1,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u6620\\u753b\\u3061\\u3044\\u304b\\u308f\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/202717\",\"description\":\"Based on a series of <i>Chiikawa<\\/i> comics posted on X by Nagano from March to November 2023, known as the <i>\\\"Siren Arc\\\"<\\/i>.<br><br>\\nOne day, while Chiikawa and Hachiware were relaxing in the square, Usagi suddenly appeared with a flyer stuck to its face. When Hachiware checked the flyer, it was an invitation reading \\u201cSpecial Invitation to a Special Island.\\u201d<br><br>\\n\\nLured by promises like \\u201cGet 100x rewards for simple island quests!\\u201d and \\u201cLimited-edition island ramen, exclusive sweets\\u2014sweet and spicy treats all practically free!\\u201d, Chiikawa and the others decided to go on the island retreat. Boarding the ship alongside Rakko, who was suspicious of the flyer's contents, the group landed on the island... only to find something waiting for them there...!?<br><br>\\n(Source: Official Site, translated)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/202717-CuvdrT9VX9Gr.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx202717-kHDn7BRiP9CR.jpg\",\"color\":\"#43bbe4\"},\"trailer\":{\"id\":\"Gk1eOaPhRJo\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/Gk1eOaPhRJo\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/chiikawa.toho-movie.jp\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/chiikawa_movie\"},{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@chiikawa_movie\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/chiikawa_movie\"}],\"rankings\":[{\"rank\":34,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7805,\"name\":\"Cypic\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7805\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PARENT\",\"node\":{\"id\":140842,\"title\":{\"romaji\":\"Chiikawa\",\"native\":\"\\u3061\\u3044\\u304b\\u308f\",\"english\":\"Chiikawa\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/140842\"}},{\"relationType\":\"SOURCE\",\"node\":{\"id\":140855,\"title\":{\"romaji\":\"Chiikawa: Nanka Chiisakute Kawaii Yatsu\",\"native\":\"\\u3061\\u3044\\u304b\\u308f \\u306a\\u3093\\u304b\\u5c0f\\u3055\\u304f\\u3066\\u304b\\u308f\\u3044\\u3044\\u3084\\u3064\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/140855\"}}]},\"airingSchedule\":{\"nodes\":[{\"episode\":1,\"airingAt\":1784818800}]}},{\"id\":208829,\"idMal\":63512,\"title\":{\"romaji\":\"Crayon Shin-chan: Kikikaikai! Ora no Youkai Vacation\",\"native\":\"\\u30af\\u30ec\\u30e8\\u30f3\\u3057\\u3093\\u3061\\u3083\\u3093 \\u5947\\u3005\\u602a\\u3005! \\u30aa\\u30e9\\u306e\\u5996\\u602a\\u30d0\\u30b1~\\u30b7\\u30e7\\u30f3\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":31},\"endDate\":{\"year\":2026,\"month\":7,\"day\":31},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Adventure\",\"Comedy\"],\"synonyms\":[\"Crayon Shin-chan the Movie: Super Strange! My Youkai Monster Vacation\"],\"duration\":null,\"popularity\":220,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u6620\\u753b\\u30af\\u30ec\\u30e8\\u30f3\\u3057\\u3093\\u3061\\u3083\\u3093\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/208829\",\"description\":\"The Nohara family go to Hiroshi's hometown of Akita to attend a famous fireworks festival during the summer. However, an incident causes youkai to escape from their land and will wreak havoc in Akita and in other areas throughout Japan. The Nohara family then go to the land of youkai and find themselves in a mysterious yet nostalgic world, where they go on an unpredictable adventure.\\n<br><br>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx208829-I72LfY7BgEZA.jpg\",\"color\":\"#e49343\"},\"trailer\":{\"id\":\"ocDkvAT4J_A\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/ocDkvAT4J_A\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"TikTok\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/196-o2g5cLUG6k5V.png\",\"color\":\"#010101\",\"url\":\"https:\\/\\/www.tiktok.com\\/@shinchan_m