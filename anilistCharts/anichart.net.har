\",\"genres\":[\"Action\",\"Adventure\",\"Fantasy\"],\"synonyms\":[\"From Overshadowed to Overpowered: Second Reincarnation of a Talentless Sage\",\"The Unsuccessful Yet Academically Unparalleled Sage: A Cheating S-Rank Sorcerer's Post-Rebirth Adventurer Log\",\"The Failed Sage's Academy Domination\"],\"duration\":null,\"popularity\":4240,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\" #\\u843d\\u7b2c\\u8ce2\\u8005\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/208044\",\"description\":\"Ephtal is reincarnated as a human, coming from modern Earth. In this new world where magic is real, he decides to devote the entirety of his life in the pursuit of magic. Despite his efforts, though, he discovers that he is absolutely talentless in magic, and breathed his last in anguish....But it isn't the end for him just yet! He reincarnates once again bearing the same name, Ephtal, 400 years later. Having retained his knowledge and power, he steals his resolve and once again sets his sights for the peak of magic!\\n<br><br>\\n(Source: Comikey)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx208044-jweYvjbGKnCo.png\",\"color\":\"#5dbbf1\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/rakudai-anime.com\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/rakudai_anime\"}],\"rankings\":[{\"rank\":30,\"type\":\"POPULAR\",\"season\":\"SUMMER\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":6125,\"name\":\"EMT Squared\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6125\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":113171,\"title\":{\"romaji\":\"Rakudai Kenja no Gakuin Musou: Nidome no Tensei, S-Rank Cheat Majutsushi Boukenroku\",\"native\":\"\\u843d\\u7b2c\\u8ce2\\u8005\\u306e\\u5b66\\u9662\\u7121\\u53cc\\uff5e\\u4e8c\\u5ea6\\u76ee\\u306e\\u8ee2\\u751f\\u3001\\uff33\\u30e9\\u30f3\\u30af\\u30c1\\u30fc\\u30c8\\u9b54\\u8853\\u5e2b\\u5192\\u967a\\u9332\\uff5e\",\"english\":\"From Overshadowed to Overpowered: Second Reincarnation of a Talentless Sage\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/113171\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":115201,\"title\":{\"romaji\":\"Rakudai Kenja no Gakuin Musou: Futatabi Tensei shita Saikyou Kenja, 400 Nengo no Sekai wo Maken de Musou\",\"native\":\"\\u843d\\u7b2c\\u8ce2\\u8005\\u306e\\u5b66\\u9662\\u7121\\u53cc \\uff5e\\u4e8c\\u5ea6\\u8ee2\\u751f\\u3057\\u305f\\u6700\\u5f37\\u8ce2\\u8005\\u3001400\\u5e74\\u5f8c\\u306e\\u4e16\\u754c\\u3092\\u9b54\\u5263\\u3067\\u7121\\u53cc\\uff5e\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/115201\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":203880,\"idMal\":63082,\"title\":{\"romaji\":\"Reiwa no Dara-san\",\"native\":\"\\u4ee4\\u548c\\u306e\\u30c0\\u30e9\\u3055\\u3093\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Horror\",\"Supernatural\"],\"synonyms\":[\"Dara-san of Reiwa\"],\"duration\":null,\"popularity\":1742,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u4ee4\\u548c\\u306e\\u30c0\\u30e9\\u3055\\u3093 #darasan\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/203880\",\"description\":\"Clouds blacken the sky and sheets of rain turn the mountain forest into a treacherous maze... A landslide crushes a razor wire fence, and buries a \\\"NO TRESPASSING\\\" sign... Two young siblings wander into a dark world where they do not belong, and a long, horrid shadow rears up to meet them- Anyway, so that's how we met Dara-san! She might look kinda scary, but just wait until you get to know her!<br><br>\\n\\n\\\"Look, I'm a god of misfortune, okay!? Aren't you kids gonna freak out about my grotesque visage!?\\\"<br><br>\\n\\n(Source: Yen Press)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx203880-lnruKftb27Nr.png\",\"color\":null},\"trailer\":{\"id\":\"ifRzd57vVJc\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/ifRzd57vVJc\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/darasan-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/darasan_anime\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":406,\"name\":\"Asahi Production\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/406\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":160722,\"title\":{\"romaji\":\"Reiwa no Dara-san\",\"native\":\"\\u4ee4\\u548c\\u306e\\u30c0\\u30e9\\u3055\\u3093\",\"english\":\"Dara-san of Reiwa\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/160722\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":196218,\"idMal\":null,\"title\":{\"romaji\":\"Ryoumin 0-Nin Start no Henkyou Ryoushu-sama\",\"native\":\"\\u9818\\u6c110\\u4eba\\u30b9\\u30bf\\u30fc\\u30c8\\u306e\\u8fba\\u5883\\u9818\\u4e3b\\u69d8\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Action\",\"Comedy\",\"Drama\",\"Fantasy\",\"Romance\",\"Slice of Life\"],\"synonyms\":[\"The Frontier Lord Begins with Zero Subjects\",\"The Frontier Lord Begins with Zero Subjects: Tales of Blue Dias and the Beastkin Alna\",\"The Population of the Frontier Owner Stars with 0.\"],\"duration\":null,\"popularity\":2648,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30a2\\u30cb\\u30e1\\u9818\\u6c11\\uff10\\u4eba #ryomin0anime\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/196218\",\"description\":\"Dias finally returns home after decades of war. He's hailed as a hero and promptly rewarded with his own domain...which turns out to be little more than empty plains. Population: zero. Dias, who has only ever known battle, finds himself at a loss. How is he supposed to survive, let alone cultivate his territory into a thriving, prosperous dominion when there's nothing but grass as far as can see? \\n<br><br>\\nFortunately for Dias, a horned girl by the name of Alna is about to show him there's more to the plains than meets the eye! \\n<br><br>\\n(Source: J-Novel Club)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx196218-GuO62b9WnV43.jpg\",\"color\":\"#5daee4\"},\"trailer\":{\"id\":\"BiDDgaQ-SKo\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/BiDDgaQ-SKo\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/ryomin0_anime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/ryomin0-anime.com\\/\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7621,\"name\":\"animation studio42\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7621\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":106767,\"title\":{\"romaji\":\"Ryoumin 0-Nin Start no Henkyou Ryoushu-sama\",\"native\":\"\\u9818\\u6c110\\u4eba\\u30b9\\u30bf\\u30fc\\u30c8\\u306e\\u8fba\\u5883\\u9818\\u4e3b\\u69d8\",\"english\":\"The Frontier Lord Begins with Zero Subjects\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/106767\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":106770,\"title\":{\"romaji\":\"Ryoumin 0-Nin Start no Henkyou Ryoushu-sama\",\"native\":\"\\u9818\\u6c110\\u4eba\\u30b9\\u30bf\\u30fc\\u30c8\\u306e\\u8fba\\u5883\\u9818\\u4e3b\\u69d8\",\"english\":\"The Frontier Lord Begins with Zero Subjects: Tales of Blue Dias and the Onikin Alna\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/106770\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":201514,\"idMal\":62876,\"title\":{\"romaji\":\"Saijo no Osewa: Takane no Hanadarake na Meimonkou de, Gakuin Ichi no Ojou-sama (Seikatsu Nouryoku Kaimu) wo Kagenagara Osewa suru Koto ni Narimashita\",\"native\":\"\\u624d\\u5973\\u306e\\u304a\\u4e16\\u8a71 \\u9ad8\\u5dba\\u306e\\u82b1\\u3060\\u3089\\u3051\\u306a\\u540d\\u9580\\u6821\\u3067\\u3001\\u5b66\\u9662\\u4e00\\u306e\\u304a\\u5b22\\u69d8(\\u751f\\u6d3b\\u80fd\\u529b\\u7686\\u7121)\\u3092\\u9670\\u306a\\u304c\\u3089\\u304a\\u4e16\\u8a71\\u3059\\u308b\\u3053\\u3068\\u306b\\u306a\\u308a\\u307e\\u3057\\u305f\",\"english\":\"Rich Girl Caretaker: I'm Secretly the Caregiver of the Most Popular Girl in This Rich Kid School\"},\"startDate\":{\"year\":2026,\"month\":7,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":\"SUMMER\",\"format\":\"TV\",\"genres\":[\"Comedy\",\"Romance\"],\"synonyms\":[\"Das (fast) perfekte Fr\\u00e4ulein und sein Butler\",\"\\u624d\\u5973\\u7684\\u4f8d\\u5f9e \\u5728\\u6eff\\u662f\\u9ad8\\u5dba\\u4e4b\\u82b1\\u7684\\u8cb4\\u65cf\\u5b78\\u6821\\u6697\\u4e2d\\u7167\\u9867\\uff08\\u6beb\\u7121\\u751f\\u6d3b\\u81ea\\u7406\\u80fd\\u529b\\u7684\\uff09\\u5b78\\u9662\\u7b2c\\u4e00\\u5927\\u5c0f\\u59d0\",\"\\u0e1c\\u0e39\\u0e49\\u0e14\\u0e39\\u0e41\\u0e25\\u0e40\\u0e14\\u0e47\\u0e01\\u0e2a\\u0e32\\u0e27\"],\"duration\":null,\"popularity\":5315,\"episodes\":null,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u624d\\u5973\\u306e\\u304a\\u4e16\\u8a71\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/201514\",\"description\":\"A poor high school boy, Itsuki Tomonari, got caught up in a kidnapping attempt on Hinako Konohana, a young lady from one of Japan's largest conglomerates. On the surface, Hinako appears to be a brilliant and beautiful young woman, but in reality, she is a lazy girl with no life skills. However, due to family reasons, Hinako has to play the role of the \\\"perfect young lady\\\" at school. Wanting to protect her, Itsuki took on the job of caring for her. Eventually, Hinako began to spoil Itsuki with all her might -- \\\"I don't want...... Itsuki to leave my side right now.\\\" This is a love story that begins beyond the master-servant relationship featuring a princess with a beautiful facade.\\n<br><br>\\n(Source: HJ Bunko, translated)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx201514-BHAeWhSbcBrT.png\",\"color\":\"#e48650\"},\"trailer\":{\"id\":\"1ueL9xwIcFQ\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/1ueL9xwIcFQ\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/saijonoosewa-anime.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/saijonoosewa_pr\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\"}],\"rankings\":[{\"rank\":25,\"type\":\"POPULAR\",\"season\":\"SUMMER\",\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":112,\"name\":\"Brain's Base\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/112\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":136332