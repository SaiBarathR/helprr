            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":true,\"total\":5000},\"media\":[{\"id\":187479,\"idMal\":null,\"title\":{\"romaji\":\"(Title to be Announced)\",\"native\":\"(Title to be Announced)\",\"english\":null},\"startDate\":{\"year\":2027,\"month\":null,\"day\":null},\"endDate\":{\"year\":2027,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[],\"synonyms\":[],\"duration\":null,\"popularity\":291,\"episodes\":null,\"source\":null,\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/187479\",\"description\":\"Feature film project directed by Kazuki Kawagoe.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/default.jpg\",\"color\":null},\"trailer\":null,\"externalLinks\":[],\"rankings\":[{\"rank\":8,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7348,\"name\":\"BUG FILMS\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7348\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":183418,\"idMal\":59878,\"title\":{\"romaji\":\"Agami\",\"native\":\"\\uc544\\uac00\\ubbf8 \",\"english\":\"Gill\"},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Drama\",\"Psychological\",\"Supernatural\"],\"synonyms\":[],\"duration\":104,\"popularity\":418,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"KR\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/183418\",\"description\":\"A boy called Gon was on the verge of death, when suddenly gills started to grow and he could breathe again. Kang Ha and his grandpa rescue Gon and together they become an odd family. This film explores life's paradoxes, blessings and curses. It will encourage you to think about your own \\\"gills\\\" to help you get through your life.<br><br>\\n\\n(Source: Annecy Festival)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/183418-JEqR1OmEo4vC.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx183418-H9kQf5985Jsm.jpg\",\"color\":\"#35a1e4\"},\"trailer\":{\"id\":\"NYm03K5kvhE\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/NYm03K5kvhE\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/watch?v=NYm03K5kvhE\"}],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":136205,\"idMal\":null,\"title\":{\"romaji\":\"Akubi wo Suru ni wa Wake ga Aru\",\"native\":\"\\u3042\\u304f\\u3073\\u3092\\u3059\\u308b\\u306b\\u306f\\u30ef\\u30b1\\u304c\\u3042\\u308b\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Drama\"],\"synonyms\":[],\"duration\":null,\"popularity\":389,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/136205\",\"description\":\"Japan, 2093. A rural town that used to be the most prestigious town in the world has long since sunk 30 meters under the ocean's surface. The story is a tale of a girl who takes part in freediving (diving without the aid of equipment to breathe), and the emotional growth she experiences. \\n<br><br>\\n(Source: Anime News Network)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b136205-OHyk4i03GO8H.png\",\"color\":\"#50a1f1\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6122,\"name\":\"Gaina\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6122\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":114441,\"idMal\":null,\"title\":{\"romaji\":\"Ane Naru Mono\",\"native\":\"\\u59c9\\u306a\\u308b\\u3082\\u306e\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"OVA\",\"genres\":[\"Ecchi\",\"Horror\",\"Romance\",\"Slice of Life\",\"Supernatural\"],\"synonyms\":[\"The Elder Sister-Like One\"],\"duration\":null,\"popularity\":6381,\"episodes\":null,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u59c9\\u306a\\u308b\\u3082\\u306e\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/114441\",\"description\":\"When an orphan encounters the eldritch demon Shub-Niggurath, the \\\"Black Goat of the Woods with a Thousand Young\\\" offers him one wish. His request: \\\"Become my big sister.\\\"<br>\\n<br>\\n(Source: Yen Press)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/114441-AZcxoW9W4YaG.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b114441-DkWOy3ykZxmt.png\",\"color\":\"#e45d93\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":87234,\"title\":{\"romaji\":\"Ane Naru Mono\",\"native\":\"\\u59c9\\u306a\\u308b\\u3082\\u306e\",\"english\":\"The Elder Sister-Like One\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/87234\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":155334,\"idMal\":null,\"title\"