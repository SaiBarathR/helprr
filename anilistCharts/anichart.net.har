Score\":65,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/179689\",\"description\":\"In an alternate fantasy world, the Demon King reigns with a formidable army led by his Four Heavenly Kings. One happens to be Uchimura Denosuke, a normal salaryman unexpectedly plucked from his mundane life by the Demon King himself. But even in this new realm, Uchimura is bestowed no particular powers. Can he survive treacherous missions with only the knowledge of an office worker?<br>\\n<br>\\n(Source: Crunchyroll)\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/179689-pmEg73tCaoMP.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx179689-kmlqdU3IbxeM.jpg\",\"color\":\"#c9e4f1\"},\"trailer\":{\"id\":\"KLL4WmHKllM\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/KLL4WmHKllM\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/salaryman-big4.com\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/salaryman_big4\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GDKHZEJPQ\\/headhunted-to-another-world-from-salaryman-to-big-four\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/playlist?list=PLxSscENEp7Jj9WjsCCnhQehPwk1vwiwnN\"},{\"site\":\"Bilibili TV\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/119-NCwGvCjFADGQ.png\",\"color\":\"#00A1D6\",\"url\":\"https:\\/\\/www.bilibili.tv\\/en\\/media\\/2122339\"}],\"rankings\":[{\"rank\":7,\"type\":\"POPUL