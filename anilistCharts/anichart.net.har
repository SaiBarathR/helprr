ps:\\/\\/anilist.co\\/studio\\/7585\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":136899,\"title\":{\"romaji\":\"Yomi no Tsugai\",\"native\":\"\\u9ec4\\u6cc9\\u306e\\u30c4\\u30ac\\u30a4\",\"english\":\"Daemons of the Shadow Realm\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/136899\"}}]}}},{\"id\":412791,\"episode\":8,\"airingAt\":1779112800,\"media\":{\"id\":147105,\"idMal\":51553,\"title\":{\"romaji\":\"Tongari Boushi no Atelier\",\"native\":\"\\u3068\\u3093\\u304c\\u308a\\u5e3d\\u5b50\\u306e\\u30a2\\u30c8\\u30ea\\u30a8\",\"english\":\"Witch Hat Atelier\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":6},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"ONA\",\"genres\":[\"Adventure\",\"Drama\",\"Fantasy\"],\"synonyms\":[\"Atelier of Witch Hat\",\" \\u0e08\\u0e2d\\u0e21\\u0e40\\u0e27\\u0e17\\u0e1d\\u0e36\\u0e01\\u0e2b\\u0e31\\u0e14\\u0e01\\u0e31\\u0e1a\\u0e2b\\u0e21\\u0e27\\u0e01\\u0e21\\u0e2b\\u0e31\\u0e28\\u0e08\\u0e23\\u0e23\\u0e22\\u0e4c\",\"Atelier spiczastych kapeluszy\",\"Cad\\u0131 \\u015eapkas\\u0131 At\\u00f6lyesi\",\"L'Atelier des Sorciers\",\"X\\u01b0\\u1edfng Ph\\u00e9p Thu\\u1eadt\",\"\\u0410\\u0442\\u0435\\u043b\\u044c\\u0435 \\u043a\\u043e\\u043b\\u0434\\u043e\\u0432\\u0441\\u043a\\u0438\\u0445 \\u043a\\u043e\\u043b\\u043f\\u0430\\u043a\\u043e\\u0432\"],\"duration\":24,\"popularity\":140688,\"episodes\":13,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3068\\u3093\\u304c\\u308a\\u5e3d\\u5b50\\u306e\\u30a2\\u30c8\\u30ea\\u30a8 #WitchHatAtelier #\\u0394\\u5e3d\\u5b50\",\"averageScore\":86,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/147105\",\"description\":\"In a world where everyone takes wonders like magic spells and dragons for granted, Coco is a girl with a simple dream: she wants to be a witch. But everybody knows magicians are born, not made, and Coco was not born with a gift for magic. Resigned to her un-magical life, Coco is about to give up on her dream to become a witch \\u2026 until the day she meets Qifrey, a mysterious, traveling magician. After secretly seeing Qifrey perform magic in a way she\\u2019s never seen before, Coco soon learns what everybody \\u201cknows\\u201d might not be the truth, and discovers that her magical dream may not be as far away as it may seem... <br>\\n<br>\\n(Source: Kodansha USA) <br><br>\\n\\n<i>Note: Tongari Boushi no Atelier episode 2 was streamed a week in advance on Crunchyroll, ABEMA, and Netflix, alongside episode 1. Streaming is one week ahead of the TV broadcast.<\\/i>\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/147105-fTjmRrILFixZ.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx147105-rwOX8qyUy8gV.jpg\",\"color\":\"#0d8693\"},\"trailer\":{\"id\":\"rc26AwBXlUE\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/rc26AwBXlUE\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/tongari_anime\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/tongari-anime.com\\/\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GT00258001\\/\"},{\"site\":\"Netflix\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/10-rVGPom8RCiwH.png\",\"color\":\"#E50914\",\"url\":\"https:\\/\\/www.netflix.com\\/title\\/82741721\"}],\"rankings\":[{\"rank\":4,\"type\":\"RATED\",\"season\":null,\"allTime\":true},{\"rank\":11,\"type\":\"POPULAR\",\"season\":null,\"allTime\":true},{\"rank\":2,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":1,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7348,\"name\":\"BUG FILMS\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7348\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":98263,\"title\":{\"romaji\":\"Tongari Boushi no Atelier\",\"native\":\"\\u3068\\u3093\\u304c\\u308a\\u5e3d\\u5b50\\u306e\\u30a2\\u30c8\\u30ea\\u30a8\",\"english\":\"Witch Hat Atelier\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/98263\"}},{\"relationType\":\"OTHER\",\"node\":{\"id\":211301,\"title\":{\"romaji\":\"Kaze no Anthem\",\"native\":\"\\u98a8\\u306e\\u30a2\\u30f3\\u30bb\\u30e0\",\"english\":\"Wind's Anthem\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/211301\"}}]}}},{\"id\":412802,\"episode\":6,\"airingAt\":1778596200,\"media\":{\"id\":186744,\"idMal\":61013,\"title\":{\"romaji\":\"Replica Datte, Koi wo Suru.\",\"native\":\"\\u30ec\\u30d7\\u30ea\\u30ab\\u3060\\u3063\\u3066\\u3001\\u604b\\u3092\\u3059\\u308b\",\"english\":\"Even a Replica Can Fall in Love\"},\"startDate\":{\"year\":2026,\"month\":4,\"day\":7},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Drama\",\"Romance\",\"Supernatural\"],\"synonyms\":[\"\\u0414\\u0430\\u0436\\u0435 \\u043a\\u043e\\u043f\\u0438\\u044f \\u0441\\u043f\\u043e\\u0441\\u043e\\u0431\\u043d\\u0430 \\u0432\\u043b\\u044e\\u0431\\u0438\\u0442\\u044c\\u0441\\u044f\"],\"duration\":24,\"popularity\":11482,\"episodes\":13,\"source\":\"LIGHT_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u30ec\\u30d7\\u30ea\\u30b3\",\"averageScore\":66,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/186744\",\"description\":\"When she doesn\\u2019t feel well, when there\\u2019s a test, when she doesn\\u2019t want to go to school... I take her place. I\\u2019m her replica. I\\u2019m not meant for anything else. But that changed when I fell in love. I wear my hair up so the boy I fell for knows it\\u2019s me. We skip school and promise to meet again tomorrow, and every day after. I\\u2019m her replica. Everything about me is borrowed and empty, but my heart is mine.<br>\\n<br>\\n(Source: Crunchyroll)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx186744-nFH4y2slUrO4.jpg\",\"color\":\"#f1f1c9\"},\"trailer\":{\"id\":\"WsT7OO91jXo\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/WsT7OO91jXo\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/REPLICO_dengeki\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/replico.jp\\/\"},{\"site\":\"Crunchyroll\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/5-AWN2pVlluCOO.png\",\"color\":\"#F88B24\",\"url\":\"https:\\/\\/www.crunchyroll.com\\/series\\/GT00374288\\/even-a-replica-can-fall-in-love\"}],\"rankings\":[{\"rank\":61,\"type\":\"RATED\",\"season\":null,\"allTime\":false},{\"rank\":99,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7362,\"name\":\"Voil\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7362\"}]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":160044,\"title\":{\"romaji\":\"Replica Datte, Koi wo Suru.\",\"native\":\"\\u30ec\\u30d7\\u30ea\\u30ab\\u3060\\u3063\\u3066\\u3001\\u604b\\u3092\\u3059\\u308b\\u3002\",\"english\":\"Even a Replica Can Fall in Love\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/160044\"}},{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":163184,\"title\":{\"romaji\":\"Replica Datte, Koi wo Suru.\",\"native\":\"\\u30ec\\u30d7\\u30ea\\u30ab\\u3060\\u3063\\u3066\\u3001\\u604b\\u3092\\u3059\\u308b\\u3002\",\"english\":\"Even a Replica Can Fall in Love\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/163184\"}