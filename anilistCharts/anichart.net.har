            "text": "{\"data\":{\"Page\":{\"pageInfo\":{\"hasNextPage\":true,\"total\":5000},\"media\":[{\"id\":206287,\"idMal\":62704,\"title\":{\"romaji\":\"Wuzhuang Fengbao\",\"native\":\"\\u6b66\\u88c5\\u98ce\\u66b4\",\"english\":\"Galactic Storm Warriors\"},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Sci-Fi\"],\"synonyms\":[],\"duration\":null,\"popularity\":66,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/206287\",\"description\":\"The young human Wang Dong vowed to avenge his parents and joined the Storm Squad, determined to exterminate the Zhage insect species across the solar system. Through hardships, he awakened his Blade Warrior powers, upgraded his armor and skills, and ultimately uncovered the insects' ultimate plot on Earth along with his team. Facing overwhelming swarms, Wang activated his ultimate Blade Warrior form and defeated both human traitors and the insect leader Ying Yuan.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx206287-J4xuPA40G0Rd.jpg\",\"color\":\"#f14378\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Youku TV\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.youku.tv\\/v\\/v_show\\/id_XNjQyNjg5OTcwNA==.html\"},{\"site\":\"Youku\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/126-QUuKXK3ri4c2.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/v.youku.com\\/v_show\\/id_XNjQzMTg2ODczNg==.html?s=beec170ae90f460e9245\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7305,\"name\":\"Qingxiang\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7305\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{