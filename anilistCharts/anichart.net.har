gram.com\\/minkymomo_ap\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/219-EwrfceXsqIWg.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/x.com\\/minkymomo_ap\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":196,\"name\":\"Ashi Productions\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/196\"},{\"id\":6460,\"name\":\"Studio Live\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6460\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PARENT\",\"node\":{\"id\":518,\"title\":{\"romaji\":\"Mahou no Princess Minky Momo\",\"native\":\"\\u9b54\\u6cd5\\u306e\\u30d7\\u30ea\\u30f3\\u30bb\\u30b9 \\u30df\\u30f3\\u30ad\\u30fc\\u30e2\\u30e2\",\"english\":\"Fairy Princess Minky Momo\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/518\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":143103,\"idMal\":50668,\"title\":{\"romaji\":\"Mahoutsukai no Yoru\",\"native\":\"\\u9b54\\u6cd5\\u4f7f\\u3044\\u306e\\u591c\",\"english\":\"Witch on the Holy Night\"},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Drama\",\"Fantasy\"],\"synonyms\":[\"Witch on the Holy Night\",\"Mahoyo\"],\"duration\":null,\"popularity\":25500,\"episodes\":1,\"source\":\"VISUAL_NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u9b54\\u6cd5\\u4f7f\\u3044\\u306e\\u591c\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/143103\",\"description\":\"Near the end of the Showa era in the late 1980s, in Misaki town, an old mansion is rumored to be the home of a witch. After moving into the mansion, Aoko Aozaki begins to learn sorcery from a young mage, Alice Kuonji, the rumored witch of the mansion. The Aozaki family oversees the land on which Misaki is built and the heir (Aoko) is tasked with protecting it.<br>\\n<br>\\nMysterious intruders have been disrupting the bounded field in Misaki, leading Alice and Aoko to investigate. A mannequin or puppet attacks them and is incinerated. As this happens, both of them spot someone running away, a civilian who must not get away having seen magic alive.<br>\\n<br>\\nUnexpectedly, a young boy named Soujuurou Shizuki is drawn to the mansion and comes to reside with them as well.\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/143103-KwDRPfPl4OwL.jpg\",\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx143103-yED3c4CaRLXO.png\",\"color\":\"#1a93e4\"},\"trailer\":{\"id\":\"T19PU9ZB_2g\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/T19PU9ZB_2g\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/mahoyo_movie\"},{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/mahoyo-movie.com\\/\"}],\"rankings\":[{\"rank\":296,\"type\":\"POPULAR\",\"season\":null,\"allTime\":true},{\"rank\":4,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":43,\"name\":\"ufotable\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/43\"}]},\"relations\":{\"edges\":[{\"relationType\":\"CHARACTER\",\"node\":{\"id\":73809,\"title\":{\"romaji\":\"Kitsy8\",\"native\":\"Kitsy8\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/73809\"}},{\"relationType\":\"SIDE_STORY\",\"node\":{\"id\":167710,\"title\":{\"romaji\":\"Mahoutsukai no Yoru\",\"native\":\"\\u9b54\\u6cd5\\u4f7f\\u3044\\u306e\\u591c\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/167710\"}},{\"relationType\":\"SIDE_STORY\",\"node\":{\"id\":186377,\"title\":{\"romaji\":\"Tsukiji Tobimaru Toiu Hito\",\"native\":\"\\u69fb\\u53f8\\u9cf6\\u4e38\\u3068\\u3044\\u3046\\u3072\\u3068\",\"english\":