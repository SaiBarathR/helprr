con\\/120-Q60x0hPKE19B.png\",\"color\":\"#E6162D\",\"url\":\"https:\\/\\/weibo.com\\/u\\/7304047806\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6546,\"name\":\"GARDEN\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6546\"}]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":103908,\"title\":{\"romaji\":\"Hen Chun Hen Aimei\",\"native\":\"\\u5f88\\u7eaf\\u5f88\\u66a7\\u6627\",\"english\":\"An Ambiguous Feeling\"},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/103908\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":191025,\"idMal\":55143,\"title\":{\"romaji\":\"HIDARI\",\"native\":\"\\u5de6\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Action\"],\"synonyms\":[],\"duration\":null,\"popularity\":440,\"episodes\":1,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u5de6 #HIDARI\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/191025\",\"description\":\"A skilled carpenter\\/sculptor Jingoro, gets set up by his disciples and loses his right arm and his father in an \\\"accident\\\" during the reconstruction of the Edo Castle. A few decades later\\u2026 Jingoro is continuing his journey of revenge with his partner \\u201cSleeping Cat\\u201d and his weaponized prosthetic arm. People have come to call him Jingoro \\\"Hidari,\\\" which means \\\"left\\\" in Japanese.<br><br>\\n\\nJingoro defeats all the foes that has betrayed him, but he learns that Tokugawa Shogunate was behind the murderous event. He searches for clues on who was behind the whole set up, and fights with an army of mechanical soldiers along the way. Finally he confronts the mastermind behind all the killings, but first, he must save the city of Edo by stopping the Edo Castle, now turned into a gigantic weapon of mass destruction!<br><br>\\n(Source: Official Website)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b191025-LHV8SkySYwlu.jpg\",\"color\":\"#d6ae78\"},\"trailer\":null,\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/hidari-movie.com\\/\"},{\"site\":\"Instagram\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/48-VFlxaXGaNqXk.png\",\"color\":\"#833AB4\",\"url\":\"https:\\/\\/www.instagram.com\\/hidari_movie\\/\"},{\"site\":\"Twitter\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/17-R0tMgOvwvhsS.png\",\"color\":\"#000000\",\"url\":\"https:\\/\\/twitter.com\\/hidari_movie\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":6179,\"name\":\"dwarf\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/6179\"}]},\"relations\":{\"edges\":[{\"relationType\":\"ALTERNATIVE\",\"node\":{\"id\":156059,\"title\":{\"romaji\":\"HIDARI (Pilot Film)\",\"native\":\"\\u5de6 \\u30d1\\u30a4\\u30ed\\u30c3\\u30c8\\u30fb\\u30d5\\u30a3\\u30eb\\u30e0\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/156059\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":164194,\"idMal\":55075,\"title\":{\"romaji\":\"Hina\",\"native\":\"\\u3072\\u306a\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":2026,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Action\",\"Drama\"],\"synonyms\":[\"\\u3072\\u306a\\u306f\\u7f8e\\u3057\\u3044\",\"Hina wa Utsukushii\",\"Hina is Beautiful\"],\"duration\":null,\"popularity\":1548,\"episodes\":1,\"source\":\"MANGA\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/164194\",\"description\":\"<i>Hina is Beautiful<\\/i> is a \\\"highly entertaining action drama\\\" film directed by Kenji Iwaisawa. Taking place in Izu, Japan, where the local men are fighting over a woman called Hina. What is it exactly that makes Hina mislead men? As the men try to confess their true feelings for Hina, strong, muscly men also get involved and the sound of the festival drum signals the start of a confrontation.\\n<br><br>\\n(Source: Variety, edited)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/b164194-IAB9AduVgDa4.jpg\",\"color\":\"#5d93e4\"},\"trailer\":null,\"externalLinks\":[],\"rankings\":[{\"rank\":30,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[{\"relationType\":\"SOURCE\",\"node\":{\"id\":165136,\"title\":{\"romaji\":\"Hina\",\"native\":\"\\u3072\\u306a\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/165136\"}},{\"relationType\":\"CHARACTER\",\"node\":{\"id\":184364,\"title\":{\"romaji\":\"Amanatsu: Arai Hideki Sakuhinshuu\",\"native\":\"\\u3042\\u307e\\u306a\\u3064 \\u65b0\\u4e95\\u82f1\\u6a39\\u4f5c\\u54c1\\u96c6\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/manga\\/184364\"}}]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":190574,\"idMal\":null,\"title\":{\"romaji\":\"Hinagiku no Jinsei\",\"native\":\"\\u3072\\u306a\\u83ca\\u306e\\u4eba\\u751f\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":null,\"day\":null},\"endDate\":{\"year\":2026,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[\"Drama\",\"Fantasy\"],\"synonyms\":[\"Daisy's Life\"],\"duration\":null,\"popularity\":613,\"episodes\":1,\"source\":\"NOVEL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/190574\",\"description\":\"\\u201cDaisy's Life\\u201d follows the emotional journey of a six-year-old girl named Daisy, who loses her mother in a tragic accident and struggles to adapt to life with her aunt. One sleepless night, she encounters a mysterious girl named Dahlia at her window. Their days together begin to transcend time and space, bringing a cosmic perspective to Daisy's modest life in a downtown yakisoba restaurant.<br><br>\\n(Source: Variety)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/default.jpg\",\"color\":null},\"trailer\":null,\"externalLinks\":[],\"rankings\":[{\"rank\":39,\"type\":\"POPULAR\",\"season\":null,\"allTime\":false}],\"studios\":{\"nodes\":[{\"id\":7651,\"name\":\"ame pippin\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7651\"}]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":104083,\"idMal\":null,\"title\":{\"romaji\":\"Hiroshima: Natsu no Nokgori no Bara\",\"native\":\"\\u30d2\\u30ed\\u30b7\\u30de\\u30fb\\u590f\\u306e\\u540d\\u6b8b\\u306e\\u30d0\\u30e9\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"MOVIE\",\"genres\":[],\"synonyms\":[\"Hiroshima: The Last Summer Rose\"],\"duration\":null,\"popularity\":108,\"episodes\":null,\"source\":null,\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/104083\",\"description\":\"The film is the dying wish of Japanese-American animation director Jimmy Murakami, who passed away in 2004 at 80 years old. Murakami is known for the animated adaptations of When the Wind Blows and The Snowman, both books by Raymond Briggs. During World War II, Murakami was imprisoned at the Tule Lake War Relocation Center internment camp. He had told friends that he wanted his last work to be themed on Hiroshima.\\n\\nMurakami had wanted the film to be based on the life's work of historian Shigeaki Mori, who has spent more than 40 years gathering details on the 12 U.S. bomber crew members and prisoners of war who were killed during the atomic bombing of Hiroshima in 1945. Mori is himself a survivor of the bombing of Hiroshima, and is the subject of a recent documentary titled Paper Lanterns, which launched digitally and on home video on August 7.\\n\\nHiroshima: The Last Summer Rose, based on Mori's books, will tell a story of an American prisoner of war and a Japanese nursing student who fall in love, but are torn apart by the atomic bombing. The title comes from the Irish folk song \\\"The Last Rose of Summer,\\\" which is itself the basis for the famous Japanese song \\\"Niwa no Chigusa.\\\"\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/medium\\/104083-i4Y9ns7QdHMI.jpg\",\"color\":null},\"trailer\":null,\"externalLinks\":[],\"rankings\":[],\"studios\":{\"nodes\":[]},\"relations\":{\"edges\":[]},\"airingSchedule\":{\"nodes\":[]}},{\"id\":141858,\"idMal\":null,\"title\":{\"romaji\":\"Hong Huang 2\",\"native\":\"\\u7ea2\\u8352 \\u7b2c\\u4e8c\\u5b63\",\"english\":null},\"startDate\":{\"year\":null,\"month\":null,\"day\":null},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"NOT_YET_RELEASED\",\"season\":null,\"format\":\"ONA\",\"genres\":[\"Action\",\"Adventure\",\"Sci-Fi\"],\"synonyms\":[\"R.E.D 2\",\"Rescue Eternal Desert 2\"],\"duration\":null,\"popularity\":57,\"episodes\":null,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"CN\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/141858\",\"description\":\"The second season of <i>Hong Huang<\\/i>.\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx141858-TnMHXlQiEIqg.png\",\"color\":\"#f1ae28\"},\"trailer\":{\"id\":\"YjdiNbyDCuA\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/YjdiNbyDCuA\\/hqdefault.jpg\"},\"externalLinks\":[