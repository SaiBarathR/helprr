"id\":412108,\"episode\":8,\"airingAt\":1778751000,\"media\":{\"id\":209541,\"idMal\":63773,\"title\":{\"romaji\":\"PetitCure: Precure Fairies Season 3\",\"native\":\"\\u3077\\u3061\\u304d\\u3085\\u3042\\uff5ePrecure Fairies\\uff5e \\u30b7\\u30fc\\u30ba\\u30f33\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":3,\"day\":26},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"ONA\",\"genres\":[\"Fantasy\",\"Slice of Life\"],\"synonyms\":[\"PuchiCure 3\"],\"duration\":null,\"popularity\":186,\"episodes\":null,\"source\":\"ORIGINAL\",\"countryOfOrigin\":\"JP\",\"hashtag\":null,\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/209541\",\"description\":\"In Season 3, in addition to the familiar Mysterious Amusement Park and Candy Paradise, many new locations\\u2014including a lively performance stage\\u2014will make their debut!<br><br>\\nFurthermore, joining the ranks of our active heroes like PetitCure Mofurun and PetitCure Pollun, new friends such as PetitCure Purirun and PetitCure Meroron will also be appearing!<br><br>\\nEverything is even cuter when you're with a friend! \\u266a<br><br>\\nPlease look forward to more heartwarming and humorous stories that will leave you feeling cozy and healed by all the cute PetitCure. \\u2661<br><br>\\n\\n(Source: Official Website)\",\"bannerImage\":null,\"isAdult\":false,\"coverImage\":{\"extraLarge\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/cover\\/large\\/bx209541-p9YKR3vE0Fx6.jpg\",\"color\":\"#d6e4a1\"},\"trailer\":{\"id\":\"4anmA68beog\",\"site\":\"youtube\",\"thumbnail\":\"https:\\/\\/i.ytimg.com\\/vi\\/4anmA68beog\\/hqdefault.jpg\"},\"externalLinks\":[{\"site\":\"Official Site\",\"icon\":null,\"color\":null,\"url\":\"https:\\/\\/www.toei-anim.co.jp\\/petitcure\\/\"},{\"site\":\"YouTube\",\"icon\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/link\\/icon\\/13-ZwR1Xwgtyrwa.png\",\"color\":\"#FF0000\",\"url\":\"https:\\/\\/www.youtube.com\\/@petitcure\"}],\"rankings\":[],\"studios\":{\"nodes\":[{\"id\":7633,\"name\":\"IKIF+\",\"siteUrl\":\"https:\\/\\/anilist.co\\/studio\\/7633\"}]},\"relations\":{\"edges\":[{\"relationType\":\"PREQUEL\",\"node\":{\"id\":199635,\"title\":{\"romaji\":\"PetitCure: Precure Fairies Season 2\",\"native\":\"\\u3077\\u3061\\u304d\\u3085\\u3042\\uff5ePrecure Fairies\\uff5e \\u30b7\\u30fc\\u30ba\\u30f3\\uff12\",\"english\":null},\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/199635\"}}]}}},{\"id\":412150,\"episode\":7,\"airingAt\":1778777400,\"media\":{\"id\":209940,\"idMal\":63709,\"title\":{\"romaji\":\"Komekami! Girls\",\"native\":\"\\u3053\\u3081\\u304b\\u307f\\u3063\\uff01Girls\",\"english\":null},\"startDate\":{\"year\":2026,\"month\":4,\"day\":3},\"endDate\":{\"year\":null,\"month\":null,\"day\":null},\"status\":\"RELEASING\",\"season\":\"SPRING\",\"format\":\"TV\",\"genres\":[\"Comedy\"],\"synonyms\":[\"\\u3053\\u3081\\u304b\\u307f\\u3063\\uff01\\u30ac\\u30fc\\u30eb\\u30ba\"],\"duration\":23,\"popularity\":803,\"episodes\":null,\"source\":\"OTHER\",\"countryOfOrigin\":\"JP\",\"hashtag\":\"#\\u3053\\u3081\\u304b\\u307f\\u3063\",\"averageScore\":null,\"siteUrl\":\"https:\\/\\/anilist.co\\/anime\\/209940\",\"description\":\"This is the story of the seven-sister unit \\\"Komekami! Girls,\\\" children of the rice deity, born from the tradition: \\\"In a single grain of rice, seven gods reside.\\\"<br><br>\\n\\nWhen their mother (the deity of rice, or the rice-god queen) was called back in haste to the celestial realm and no longer able to return to the earthly realm they search for her traces using Usa City (Oita Prefecture) as their base, and teleport to Hachiman shrines throughout Kyushu island. As they solve local problems, they learn about food, take part in cooking battles, and grow.\",\"bannerImage\":\"https:\\/\\/s4.anilist.co\\/file\\/anilistcdn\\/media\\/anime\\/banner\\/209940-5otPJXyKJkbf.jpg\",\"isAdult\":false,\"coverImage\":{\