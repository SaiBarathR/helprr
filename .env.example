# Docker (the normal case): run `./scripts/setup-env.sh` from a clone, or place
# the downloaded helper beside this template and run `./setup-env.sh`. It creates
# `.env` with private permissions and generated required secrets. Leave DATABASE_URL
# and REDIS_URL unset — compose
# wires them to the bundled Postgres/Redis containers automatically.
# Local development: copy to `.env.local` instead and set the two URLs to your
# own localhost services.
# Helprr intentionally refuses to start while any required value still uses a
# shipped change-me/example credential. Startup errors name variables but never
# print their values.

# --- Required ---
# Docker: DO NOT set — docker-compose.yml derives it from POSTGRES_PASSWORD and
# points it at the bundled `helprr-db` container. Setting it here overrides that
# (inside the container, `localhost` is the app itself — the app will crash-loop
# with "Can't reach database server"). Set only for local dev or an external DB.
# DATABASE_URL=postgresql://postgres:password-add-here@localhost:5432/helprr

# Docker: DO NOT set — defaults to the bundled `helprr-redis` container.
# Set only for local dev or an external Redis.
# REDIS_URL=redis://localhost:6379

# Redis AUTH password (required). Redis is started with --requirepass ${REDIS_PASSWORD} and the
# app sends it as the client's AUTH password. The app refuses to start without it.
REDIS_PASSWORD=change-me-redis

# For docker-compose (required; compose refuses to start without it). The default
# DATABASE_URL in docker-compose.yml embeds this password — if it contains URL
# special characters (@ : / ? #), set DATABASE_URL explicitly, percent-encoded.
POSTGRES_PASSWORD=change-me-postgres

# Seeds the bootstrap admin password on first boot only. New or force-reset
# local passwords must contain at least 15 characters. NOT checked at login
# afterward — login verifies the per-user scrypt hash stored in the DB. Changing
# this later and restarting does nothing unless HELPRR_ADMIN_PASSWORD_RESET=true.
APP_PASSWORD=change-me
# Bootstrap admin login username (optional; defaults to "admin")
HELPRR_ADMIN_USERNAME=admin
# Recovery only: set to true to force-reset the bootstrap admin's password from
# APP_PASSWORD on the next boot, then remove it (otherwise every reboot re-hashes
# from APP_PASSWORD and overwrites any password set in-app). Resets only the admin.
# HELPRR_ADMIN_PASSWORD_RESET=true
TZ=Asia/Kolkata
LOG_DIR=/app/logs

# Public HTTPS origin, required only for AniList OAuth in production.
# APP_ORIGIN=https://helprr.example.com
# Set only behind a trusted reverse proxy that sanitizes X-Forwarded-* headers.
# TRUST_FORWARDED_PROTO=true

# Secret used to sign the session cookie. Must be at least 32 characters — the
# app refuses to boot otherwise. Generate a strong value with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-32+-char-random-value


# --- Optional: Web Push (enables push notifications) ---
# Generate with: npx web-push generate-vapid-keys
# All three are runtime config — no rebuild needed after changing them.
# (The old NEXT_PUBLIC_VAPID_PUBLIC_KEY name is still accepted.)
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=


# --- Optional: server-side media cache (seconds) ---
# Directory used for image byte cache
IMAGE_CACHE_DIR=/tmp/helprr-image-cache
# Freshness window for cached images 7 days
IMAGE_CACHE_TTL_SECONDS=604800
# Stale-if-error window for cached images # 30 days
IMAGE_CACHE_STALE_SECONDS=2592000 
# Upstream image request timeout in milliseconds
IMAGE_UPSTREAM_FETCH_TIMEOUT_MS=5000
# Comma-separated trusted external hosts allowed by the image proxy.
# EXTRA_ALLOWED_IMAGE_HOSTS=images.example.com
# Enables custom HTTP headers for supported services behind an auth proxy.
# HELPRR_CUSTOM_HEADERS=true
# Optional TMDB cache tuning
# Default cache TTL (10 minutes)
TMDB_CACHE_DEFAULT_TTL_SECONDS=600
# Discovery cache TTL (10 minutes)
TMDB_CACHE_DISCOVER_TTL_SECONDS=600
# 1 day
TMDB_CACHE_DETAILS_TTL_SECONDS=86400 
# 7 days
TMDB_CACHE_STATIC_TTL_SECONDS=604800 
# 30 days
TMDB_CACHE_STALE_SECONDS=2592000 
# Cache-fill lock duration in milliseconds
CACHE_LOCK_TTL_MS=10000

# --- Optional: local development ---
# Extra origins allowed to reach the dev server (LAN IP, Tailscale hostname).
# Dev-only; ignored in production builds.
# ALLOWED_DEV_ORIGINS=192.168.0.20,my-machine.tailnet.ts.net

# --- Optional: Docker image version ---
# Published image tag used by docker-compose.yml (default: stable). Pin an exact
# version for reproducible deploys. Do NOT point this stack at `edge` — test
# development builds with the isolated dev stack (docker-compose.dev.yml) instead.
# HELPRR_VERSION=1.0.0
