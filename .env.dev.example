# Isolated development stack configuration.
#
# Run `./scripts/setup-env.sh --dev` to create .env.dev with generated
# development-only secrets, then always invoke Compose with both flags:
#   docker compose --env-file .env.dev -f docker-compose.dev.yml ...
#
# The HELPRR_DEV_* names are deliberate: this file cannot accidentally provide
# the stable stack's POSTGRES_PASSWORD, REDIS_PASSWORD, or DATABASE_URL.
# The unchanged template is intentionally non-runnable: startup rejects every
# shipped change-me credential without printing secret values.

# --- Development image mode ---
# Local source build (run Compose with --build):
HELPRR_DEV_IMAGE=helprr-dev:local
HELPRR_DEV_APP_VERSION=development
# Optional build identity shown in Settings -> Status. Set to `git rev-parse --short HEAD`.
HELPRR_DEV_GIT_SHA=local

# To run the image published from the development branch instead, change to:
# HELPRR_DEV_IMAGE=ghcr.io/saibarathr/helprr:edge
# Then use `docker compose ... pull helprr-dev` followed by `up -d --no-build`.

# --- Separate host ports ---
HELPRR_DEV_APP_PORT=3051
# PostgreSQL and Redis bind to 127.0.0.1 only.
HELPRR_DEV_POSTGRES_PORT=5433
HELPRR_DEV_REDIS_PORT=6380

# --- Required development-only secrets ---
# Use URL-safe hex for PostgreSQL because it is embedded in DATABASE_URL:
#   openssl rand -hex 32
HELPRR_DEV_POSTGRES_PASSWORD=change-me-dev-postgres
# Generate independently from the PostgreSQL password:
#   openssl rand -hex 32
HELPRR_DEV_REDIS_PASSWORD=change-me-dev-redis

# Seeds only the development bootstrap admin on the first development boot.
# New or force-reset local passwords must contain at least 15 characters.
HELPRR_DEV_APP_PASSWORD=change-me-dev-admin-password
HELPRR_DEV_ADMIN_USERNAME=dev-admin
# Recovery only; set temporarily, restart once, then remove/blank it.
# HELPRR_DEV_ADMIN_PASSWORD_RESET=true

# Must be at least 32 characters and must not match production:
#   openssl rand -base64 48
HELPRR_DEV_JWT_SECRET=change-me-to-a-separate-32+-character-development-secret

HELPRR_DEV_TZ=Asia/Kolkata

# --- Optional development Web Push ---
# Use a separate pair from production:
#   npx web-push generate-vapid-keys
HELPRR_DEV_VAPID_SUBJECT=mailto:you@example.com
HELPRR_DEV_VAPID_PUBLIC_KEY=
HELPRR_DEV_VAPID_PRIVATE_KEY=

# Set these only when the development instance has its own HTTPS origin.
# HELPRR_DEV_APP_ORIGIN=https://helprr-dev.example.com
# HELPRR_DEV_TRUST_FORWARDED_PROTO=true

# Optional integrations and cache tuning use the same defaults as stable.
# HELPRR_DEV_CUSTOM_HEADERS=true
# HELPRR_DEV_EXTRA_ALLOWED_IMAGE_HOSTS=images.example.com
# HELPRR_DEV_IMAGE_CACHE_TTL_SECONDS=604800
# HELPRR_DEV_IMAGE_CACHE_STALE_SECONDS=2592000
# HELPRR_DEV_IMAGE_UPSTREAM_FETCH_TIMEOUT_MS=5000
# HELPRR_DEV_TMDB_CACHE_DEFAULT_TTL_SECONDS=600
# HELPRR_DEV_TMDB_CACHE_DISCOVER_TTL_SECONDS=600
# HELPRR_DEV_TMDB_CACHE_DETAILS_TTL_SECONDS=86400
# HELPRR_DEV_TMDB_CACHE_STATIC_TTL_SECONDS=604800
# HELPRR_DEV_TMDB_CACHE_STALE_SECONDS=2592000
# HELPRR_DEV_CACHE_LOCK_TTL_MS=10000
