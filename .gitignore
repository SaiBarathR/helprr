# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.playwright-mcp
.pw-scratch
.cursor

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/public/sw.js

# misc
.DS_Store
*.pem
docs
.claude

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/logs/
/backups/

# env files (examples are safe to commit; real values are not)
.env*
!.env.example
!.env.dev.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude
/jellyfinDocs
/plans
/docs

# Versioned project guides and README captures
!/docs/
!/docs/*.md
!/docs/screenshots/
!/docs/screenshots/*.jpg
!/docs/screenshots/*.webp

# Captured request artifacts
*.har
anilistCharts/
postman/
