generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceType {
  SONARR
  RADARR
  QBITTORRENT
  PROWLARR
  JELLYFIN
  TMDB
  ANILIST
  SEERR
  LIDARR
}

enum UserRole {
  admin
  member
}

enum UserStatus {
  active
  pending
  disabled
}

model User {
  id             String     @id @default(cuid())
  username       String     @unique
  displayName    String
  passwordHash   String? // nullable → Jellyfin-only accounts (local login impossible, JF login works)
  role           UserRole   @default(member)
  status         UserStatus @default(active)
  template       String     @default("member") // "admin" | "member" — preset the overrides layer on
  permissions    Json       @default("{}") // Partial<Record<Capability, boolean>> — DELTAS only
  jellyfinUserId String?    @unique
  seerrUserId    String?    @unique
  jellyfinToken  String? // cached AccessToken from "Sign in with Jellyfin"; non-authoritative
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  sessions       Session[]
  watchlistItems WatchlistItem[]
  watchlistTags  WatchlistTag[]
  pushSubscriptions PushSubscription[]
  notificationHistory NotificationHistory[]
  pendingRequests PendingRequest[]
  dashboardLayouts DashboardLayout[]
  aniListLink    UserAniListLink?
  settings       UserSettings?

  @@index([jellyfinUserId])
  @@index([status])
}

model ServiceConnection {
  id             String      @id @default(cuid())
  type           ServiceType
  label          String // user-facing instance name ("HD", "4K", "Anime"); for single-instance types defaults to the service name
  isDefault      Boolean     @default(false) // exactly one true per type, enforced in arr-instances.ts
  url            String
  apiKey         String
  username       String?
  externalUrl    String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  pollingState   PollingState?

  @@unique([type, label])
  @@index([type])
}

model Session {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  userAgent  String?
  ip         String?
  label      String?
  revokedAt  DateTime?
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([revokedAt])
  @@index([userId])
}

model WatchlistItem {
  id                 String         @id @default(cuid())
  // Nullable so `db push` can add it to a populated table non-destructively;
  // ensureBootstrapAdmin() backfills existing rows to the admin on boot, and
  // every write sets it. The unique below is per-user.
  userId             String?
  user               User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  source             String
  externalId         String
  mediaType          String
  title              String
  year               Int?
  posterUrl          String?
  overview           String?
  rating             Float?
  addedAt            DateTime       @default(now())
  reminderAt         DateTime?
  reminderNotifiedAt DateTime?
  reminderAttempts   Int            @default(0)
  tags               WatchlistTag[] @relation("WatchlistItemTags")

  @@unique([userId, source, externalId, mediaType])
  @@index([userId, addedAt])
  @@index([reminderAt, reminderNotifiedAt])
}

model WatchlistTag {
  id     String          @id @default(cuid())
  // Per-user: tags are a private vocabulary, never shared across accounts.
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String?
  items  WatchlistItem[] @relation("WatchlistItemTags")

  @@unique([userId, name])
  @@index([userId])
}

model PushSubscription {
  id                  String                   @id @default(cuid())
  // Nullable for non-destructive `db push`; set at subscribe time and
  // backfilled to the admin on boot. endpoint stays globally unique.
  userId              String?
  user                User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint            String                   @unique
  p256dh              String
  auth                String
  deviceName          String?
  consecutiveFailures Int                      @default(0)
  lastFailedAt        DateTime?
  lastSucceededAt     DateTime?
  revokedAt           DateTime?
  createdAt           DateTime                 @default(now())
  preferences         NotificationPreference[]

  @@index([userId])
}

model NotificationPreference {
  id             String           @id @default(cuid())
  subscriptionId String
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType      String
  enabled        Boolean          @default(true)
  tagFilter      String?
  qualityFilter  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([subscriptionId, eventType])
}

model NotificationHistory {
  id        String   @id @default(cuid())
  // Nullable on purpose: ownership-scoped events (watchlist reminders, a
  // member's request updates) stamp the owner; instance/infrastructure events
  // (imports, health, cleanup) stay null = admin/global. Avoids a hard backfill.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String
  title     String
  body      String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  dedupeKey String?

  @@index([eventType, dedupeKey])
  // Covers the upcomingPremiere dedupe prefetch in polling-service
  // (eventType equality + createdAt range) so it seeks the slice instead of
  // range-scanning createdAt and filtering eventType in memory.
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model PollingState {
  id                  String            @id @default(cuid())
  serviceConnectionId String            @unique
  connection          ServiceConnection @relation(fields: [serviceConnectionId], references: [id], onDelete: Cascade)
  lastQueueIds        Json              @default("[]")
  lastHistoryDate     DateTime?
  lastHistoryId       Int?              // max history id at lastHistoryDate; tie-breaks same-timestamp records
  lastHealthHash      String?
  lastReachable       Boolean?          // null = not yet probed; used for service up/down transition alerts
  updatedAt           DateTime          @updatedAt
}

model AppSettings {
  id                       String  @id @default("singleton")
  pollingIntervalSecs      Int     @default(30)
  activityRefreshIntervalSecs  Int @default(5)
  torrentsRefreshIntervalSecs  Int @default(5)
  cacheImagesEnabled       Boolean @default(true)
  timeZone                 String  @default("UTC")
  logEnabled               Boolean @default(true)
  logLevel                 String  @default("debug")
  logMaxFileMb             Int     @default(50)
  logRetentionDays         Int     @default(30)
  notificationHistoryRetentionDays Int @default(90)
  logClientConsoleEnabled  Boolean @default(true)
  logFailedRequestBodies   Boolean @default(false)
  logFailedResponseBodies  Boolean @default(false)
  upcomingNotifyMode       String  @default("before_air") // "before_air" | "daily_digest"
  upcomingNotifyBeforeMins Int     @default(60)           // 0 = at air time
  upcomingDailyNotifyHour  Int     @default(9)            // 0-23, for daily_digest mode
  watchProviderRegion      String  @default("US")         // ISO 3166-1 alpha-2 country for TMDB watch providers
  activityDigestMode       String  @default("off")        // "off" | "daily" | "weekly"
  activityDigestHour       Int     @default(8)            // 0-23, hour of day to fire the digest
  activityDigestDayOfWeek  Int     @default(1)            // 0=Sun..6=Sat, used when mode=weekly
  notificationGroupingEnabled Boolean @default(true)      // collapse same-type per-poll bursts (e.g. a season pack) into one grouped notification
  animeAutoMapEnabled      Boolean  @default(true)         // nightly job that auto-maps never-mapped Sonarr anime to AniList
  animeAutoMapHour         Int      @default(0)            // 0-23 local hour the nightly drain starts (default midnight)
  animeAutoMapLastRunAt    DateTime?                       // server-managed: when the last nightly drain completed
  // AniList API cache TTLs in minutes, per policy class. Stale-serve windows
  // scale with each class's default ratio (sections/browse ×6, detail ×7, airing ×3).
  anilistSectionsTtlMin    Int     @default(5)             // home / trending / seasonal rails
  anilistBrowseTtlMin      Int     @default(10)            // search + browse results
  anilistDetailTtlMin      Int     @default(1440)          // anime/manga/staff/character/studio details
  anilistAiringTtlMin      Int     @default(10)            // next-airing + airing schedule
  qbtBandwidthSchedule     Json?                          // Bandwidth-schedule rules applied to qBittorrent global limits
  discoverLayout           Json?                          // User-configured discover homepage layout (sections order, visibility, custom carousels)
  defaultDesktopLayoutId   String?                        // Active DashboardLayout for desktop viewport
  defaultMobileLayoutId    String?                        // Active DashboardLayout for mobile viewport

  defaultDesktopLayout DashboardLayout? @relation("DesktopDefault", fields: [defaultDesktopLayoutId], references: [id], onDelete: SetNull)
  defaultMobileLayout  DashboardLayout? @relation("MobileDefault", fields: [defaultMobileLayoutId], references: [id], onDelete: SetNull)
}

model DashboardLayout {
  id        String   @id @default(cuid())
  // null = global/admin layout (the shared built-ins); non-null = a member's
  // own personal layout. Each user manages only their own scope.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  widgets   Json     // WidgetInstance[]
  isBuiltIn Boolean  @default(false)
  // Only the two global built-ins use 'desktop'/'mobile'; per-user layouts are
  // null (Postgres @unique permits multiple NULLs).
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desktopDefaults AppSettings[] @relation("DesktopDefault")
  mobileDefaults  AppSettings[] @relation("MobileDefault")

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// Per-user AniList token + identity. The global ServiceConnection(type=ANILIST)
// keeps holding the app credential (clientId/secret); this holds each member's
// OAuth tokens (encrypted) and resolved AniList identity.
model UserAniListLink {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken    String? // encrypted (enc:v1:)
  refreshToken   String? // encrypted (enc:v1:)
  tokenExpiresAt DateTime?
  anilistUserId  Int?
  username       String?
  avatar         String?
  siteUrl        String?
  scoreFormat    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Genuinely-personal settings. Every column is nullable = "inherit AppSettings".
// getUserSettings() coalesces these against the global singleton.
model UserSettings {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeZone               String?
  upcomingNotifyMode     String?
  activityDigestMode     String?
  defaultDesktopLayoutId String?
  defaultMobileLayoutId  String?
  quietHoursEnabled      Boolean  @default(false) // when true, suppress non-critical pushes during the window
  quietHoursStart        Int?                      // 0-23 local hour (in this user's timeZone) the window opens
  quietHoursEnd          Int?                      // 0-23 local hour the window closes; start > end = crosses midnight
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Helprr-side approval gate for Seerr requests. Jellyseerr's API auto-approves
// anything created with the admin key (approval is tied to the authenticating
// user, not the attributed one), so a member's request is parked here until an
// admin approves it — at which point it's created in Seerr and this row deleted.
// Transient: only pending rows ever exist (approve/decline remove them).
model PendingRequest {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType         String // 'movie' | 'tv'
  tmdbId            Int
  title             String?
  posterUrl         String?
  is4k              Boolean  @default(false)
  seasons           Json? // number[]
  serverId          Int?
  profileId         Int?
  rootFolder        String?
  languageProfileId Int?
  tags              Json? // number[]
  seerrUserId       String? // attributed member's Seerr user id (snapshot)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model AniListSeriesMapping {
  id                   String   @id @default(cuid())
  sonarrInstanceId     String
  sonarrSeriesId       Int
  state                String
  matchMethod          String?
  confidence           Int?
  seriesTitleSnapshot  String
  seriesYearSnapshot   Int?
  seriesTvdbIdSnapshot Int?
  seriesTmdbIdSnapshot Int?
  resolvedAt           DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  // 1 Sonarr series → N AniList entries (season-split anime). Matched states have
  // ≥1 entry; AUTO_UNMATCHED / MANUAL_NONE have none.
  entries              AniListSeriesMappingEntry[]

  // A series id is only unique within a Sonarr instance, so scope by instance.
  @@unique([sonarrInstanceId, sonarrSeriesId])
  @@index([sonarrInstanceId])
}

model AniListSeriesMappingEntry {
  id             String               @id @default(cuid())
  mappingId      String
  mapping        AniListSeriesMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  anilistMediaId Int
  isPrimary      Boolean              @default(false) // exactly one true per mapping
  order          Int                  @default(0) // tab order on the series detail page
  source         String               @default("manual") // 'auto' | 'manual' — who created the link
  titleSnapshot  String? // AniList preferred title at link time (admin list renders without API calls)
  createdAt      DateTime             @default(now())

  @@unique([mappingId, anilistMediaId])
  @@index([anilistMediaId]) // reverse lookup: AniList entry → Sonarr series
}

// ==================== Cleanup: Queue Cleaner ====================

model QueueCleanerConfig {
  id                            String   @id @default("singleton")
  enabled                       Boolean  @default(false)
  intervalMinutes               Int      @default(5)
  ignoredDownloads              Json     @default("[]")
  processNoContentId            Boolean  @default(false)
  downloadingMetadataMaxStrikes Int      @default(0)
  failedImport                  Json     @default("{}")
  reSearchAfterRemoval          Boolean  @default(true)
  // "disabled" (default — no auto cycles), "dryRun" (auto cycles, log only), "enabled" (auto delete)
  autoRunMode                   String   @default("disabled")
  updatedAt                     DateTime @updatedAt
}

model StallRule {
  id                      String   @id @default(cuid())
  name                    String
  enabled                 Boolean  @default(true)
  priority                Int      @default(0)
  maxStrikes              Int      @default(3)
  privacyType             String   @default("public")
  minCompletionPercentage Int      @default(0)
  maxCompletionPercentage Int      @default(100)
  resetStrikesOnProgress  Boolean  @default(true)
  minimumProgressBytes    BigInt?
  changeCategory          Boolean  @default(false)
  deletePrivate           Boolean  @default(false)
  reSearchOverride        Boolean?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model SlowRule {
  id                      String   @id @default(cuid())
  name                    String
  enabled                 Boolean  @default(true)
  priority                Int      @default(0)
  maxStrikes              Int      @default(3)
  privacyType             String   @default("public")
  minCompletionPercentage Int      @default(0)
  maxCompletionPercentage Int      @default(100)
  minSpeedKbps            Int?
  maxTimeHours            Float?
  ignoreAboveSizeBytes    BigInt?
  resetStrikesOnProgress  Boolean  @default(true)
  changeCategory          Boolean  @default(false)
  deletePrivate           Boolean  @default(false)
  reSearchOverride        Boolean?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== Cleanup: Download Cleaner ====================

model DownloadCleanerConfig {
  id                            String   @id @default("singleton")
  enabled                       Boolean  @default(false)
  intervalMinutes               Int      @default(60)
  ignoredDownloads              Json     @default("[]")
  autoRemoveImportedEnabled     Boolean  @default(false)
  autoRemoveImportedCategories  Json     @default("[\"sonarr\",\"radarr\",\"tv-sonarr\"]")
  autoRemoveImportedDeleteFiles Boolean  @default(true)
  // 'public' | 'private' | 'both'. Controls which trackers the system rule
  // applies to. Default 'public' matches historical behaviour.
  autoRemoveImportedPrivacyType String   @default("public")
  // "disabled" (default — no auto cycles), "dryRun" (auto cycles, log only), "enabled" (auto delete)
  autoRunMode                   String   @default("disabled")
  updatedAt                     DateTime @updatedAt
}

model SeedingRule {
  id                String   @id @default(cuid())
  name              String
  enabled           Boolean  @default(true)
  priority          Int      @default(0)
  categories        Json     @default("[]")
  trackerPatterns   Json     @default("[]")
  tagsAny           Json     @default("[]")
  tagsAll           Json     @default("[]")
  privacyType       String   @default("both")
  maxRatio          Float    @default(-1)
  minSeedTimeHours  Float    @default(0)
  maxSeedTimeHours  Float    @default(-1)
  deleteSourceFiles Boolean  @default(true)
  // When true, deletion is gated on Sonarr/Radarr history confirming a
  // successful import for this torrent. The ratio/seedtime predicate still
  // applies on top, so users can compose "imported AND seeded N hours".
  // Mutually exclusive with DownloadCleanerConfig.autoRemoveImportedEnabled
  // (enforced at the API layer).
  requireImportedConfirmation Boolean @default(false)
  isSystem          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ==================== Cleanup: shared ====================

model CleanupStrike {
  id                  String   @id @default(cuid())
  hash                String
  torrentName         String
  ruleId              String?
  strikeType          String
  count               Int      @default(0)
  lastDownloadedBytes BigInt?
  lastSeenAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([hash, strikeType, ruleId])
  @@index([hash])
}

enum CleanupAction {
  strikeAdded
  removedFromClient
  removedFromQueue
  categoryChanged
  skipped
  dryRunPreview
  failed
}

model CleanupHistory {
  id              String        @id @default(cuid())
  cleaner         String
  strikeType      String?
  ruleId          String?
  ruleName        String?
  hash            String
  shortHash       String
  torrentName     String
  reason          String
  action          CleanupAction
  filesDeleted    Boolean
  reSearched      Boolean
  linkedArrSource String?
  linkedArrTitle  String?
  linkedArrItemId Int?
  torrentSize     BigInt?
  torrentProgress Float?
  torrentRatio    Float?
  triggeredBy     String
  errorMessage    String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([hash])
  @@index([action])
}

// ==================== File operations: audit trail ====================

enum FileOperation {
  EDIT // bulk metadata edit (quality / language / release group / flags / release type / edition)
  DELETE // remove file(s) from disk (recycle bin or permanent, per the *arr config)
  IMPORT // manual import of loose/unmapped files (moves + renames on disk)
}

// Accountability log for Manage Episodes / Manage Files. These operations touch
// the user's own media on disk and are largely irreversible, so every attempt —
// success OR failure — is recorded with the acting user. userId is a plain
// (unlinked) string and username is denormalized so a row OUTLIVES the user it
// references (deleting a user must never erase who deleted a file). No FK/cascade
// on purpose — mirrors CleanupHistory.triggeredBy.
model FileOperationAudit {
  id           String        @id @default(cuid())
  userId       String? // acting user id at the time (not a FK — see above)
  username     String // denormalized actor, retained after user deletion
  service      ServiceType // SONARR | RADARR
  instanceId   String? // which ServiceConnection instance the op ran against
  operation    FileOperation
  mediaType    String // "series" | "movie"
  mediaId      Int // Sonarr seriesId / Radarr movieId
  mediaTitle   String
  fileCount    Int // number of files targeted
  details      Json? // file paths, field deltas, recycleBinConfigured, importMode, command id, per-file results
  success      Boolean
  errorMessage String?
  createdAt    DateTime      @default(now())

  @@index([createdAt])
  @@index([service, mediaId])
  @@index([userId, createdAt])
}
