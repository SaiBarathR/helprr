generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceType {
  SONARR
  RADARR
  QBITTORRENT
  PROWLARR
  JELLYFIN
  TMDB
  ANILIST
}

model ServiceConnection {
  id             String      @id @default(cuid())
  type           ServiceType @unique
  url            String
  apiKey         String
  username       String?
  externalUrl    String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Session {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  userAgent  String?
  ip         String?
  label      String?
  revokedAt  DateTime?

  @@index([revokedAt])
}

model WatchlistItem {
  id                 String         @id @default(cuid())
  source             String
  externalId         String
  mediaType          String
  title              String
  year               Int?
  posterUrl          String?
  overview           String?
  rating             Float?
  addedAt            DateTime       @default(now())
  reminderAt         DateTime?
  reminderNotifiedAt DateTime?
  tags               WatchlistTag[] @relation("WatchlistItemTags")

  @@unique([source, externalId, mediaType])
  @@index([addedAt])
  @@index([reminderAt, reminderNotifiedAt])
}

model WatchlistTag {
  id    String          @id @default(cuid())
  name  String          @unique
  color String?
  items WatchlistItem[] @relation("WatchlistItemTags")
}

model PushSubscription {
  id                  String                   @id @default(cuid())
  endpoint            String                   @unique
  p256dh              String
  auth                String
  deviceName          String?
  consecutiveFailures Int                      @default(0)
  lastFailedAt        DateTime?
  lastSucceededAt     DateTime?
  revokedAt           DateTime?
  createdAt           DateTime                 @default(now())
  preferences         NotificationPreference[]
}

model NotificationPreference {
  id             String           @id @default(cuid())
  subscriptionId String
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType      String
  enabled        Boolean          @default(true)
  tagFilter      String?
  qualityFilter  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([subscriptionId, eventType])
}

model NotificationHistory {
  id        String   @id @default(cuid())
  eventType String
  title     String
  body      String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PollingState {
  id              String   @id @default(cuid())
  serviceType     ServiceType @unique
  lastQueueIds    Json     @default("[]")
  lastHistoryDate DateTime?
  lastHealthHash  String?
  updatedAt       DateTime @updatedAt
}

model AppSettings {
  id                       String  @id @default("singleton")
  pollingIntervalSecs      Int     @default(30)
  activityRefreshIntervalSecs  Int @default(5)
  torrentsRefreshIntervalSecs  Int @default(5)
  cacheImagesEnabled       Boolean @default(true)
  timeZone                 String  @default("UTC")
  logEnabled               Boolean @default(true)
  logLevel                 String  @default("debug")
  logMaxFileMb             Int     @default(50)
  logRetentionDays         Int     @default(30)
  logClientConsoleEnabled  Boolean @default(true)
  logFailedRequestBodies   Boolean @default(false)
  logFailedResponseBodies  Boolean @default(false)
  upcomingAlertHours       Int     @default(24)
  upcomingNotifyMode       String  @default("before_air") // "once_in_window" | "before_air" | "daily_digest"
  upcomingNotifyBeforeMins Int     @default(60)
  upcomingDailyNotifyHour  Int     @default(9)            // 0-23, for daily_digest mode
  discoverLayout           Json?                          // User-configured discover homepage layout (sections order, visibility, custom carousels)
  defaultDesktopLayoutId   String?                        // Active DashboardLayout for desktop viewport
  defaultMobileLayoutId    String?                        // Active DashboardLayout for mobile viewport

  defaultDesktopLayout DashboardLayout? @relation("DesktopDefault", fields: [defaultDesktopLayoutId], references: [id], onDelete: SetNull)
  defaultMobileLayout  DashboardLayout? @relation("MobileDefault", fields: [defaultMobileLayoutId], references: [id], onDelete: SetNull)
}

model DashboardLayout {
  id        String   @id @default(cuid())
  name      String   @unique
  widgets   Json     // WidgetInstance[]
  isBuiltIn Boolean  @default(false)
  slug      String?  @unique // 'desktop' | 'mobile' for built-ins; null otherwise
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  desktopDefaults AppSettings[] @relation("DesktopDefault")
  mobileDefaults  AppSettings[] @relation("MobileDefault")

  @@index([createdAt])
}

model AniListSeriesMapping {
  id                   String   @id @default(cuid())
  sonarrSeriesId       Int      @unique
  anilistMediaId       Int?
  state                String
  matchMethod          String?
  confidence           Int?
  seriesTitleSnapshot  String
  seriesYearSnapshot   Int?
  seriesTvdbIdSnapshot Int?
  seriesTmdbIdSnapshot Int?
  resolvedAt           DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ==================== Cleanup: Queue Cleaner ====================

model QueueCleanerConfig {
  id                            String   @id @default("singleton")
  enabled                       Boolean  @default(false)
  intervalMinutes               Int      @default(5)
  ignoredDownloads              Json     @default("[]")
  processNoContentId            Boolean  @default(false)
  downloadingMetadataMaxStrikes Int      @default(0)
  failedImport                  Json     @default("{}")
  reSearchAfterRemoval          Boolean  @default(true)
  // "disabled" (default — no auto cycles), "dryRun" (auto cycles, log only), "enabled" (auto delete)
  autoRunMode                   String   @default("disabled")
  updatedAt                     DateTime @updatedAt
}

model StallRule {
  id                      String   @id @default(cuid())
  name                    String
  enabled                 Boolean  @default(true)
  priority                Int      @default(0)
  maxStrikes              Int      @default(3)
  privacyType             String   @default("public")
  minCompletionPercentage Int      @default(0)
  maxCompletionPercentage Int      @default(100)
  resetStrikesOnProgress  Boolean  @default(true)
  minimumProgressBytes    BigInt?
  changeCategory          Boolean  @default(false)
  deletePrivate           Boolean  @default(false)
  reSearchOverride        Boolean?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model SlowRule {
  id                      String   @id @default(cuid())
  name                    String
  enabled                 Boolean  @default(true)
  priority                Int      @default(0)
  maxStrikes              Int      @default(3)
  privacyType             String   @default("public")
  minCompletionPercentage Int      @default(0)
  maxCompletionPercentage Int      @default(100)
  minSpeedKbps            Int?
  maxTimeHours            Float?
  ignoreAboveSizeBytes    BigInt?
  resetStrikesOnProgress  Boolean  @default(true)
  changeCategory          Boolean  @default(false)
  deletePrivate           Boolean  @default(false)
  reSearchOverride        Boolean?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ==================== Cleanup: Download Cleaner ====================

model DownloadCleanerConfig {
  id                            String   @id @default("singleton")
  enabled                       Boolean  @default(false)
  intervalMinutes               Int      @default(60)
  ignoredDownloads              Json     @default("[]")
  autoRemoveImportedEnabled     Boolean  @default(false)
  autoRemoveImportedCategories  Json     @default("[\"sonarr\",\"radarr\",\"tv-sonarr\"]")
  autoRemoveImportedDeleteFiles Boolean  @default(true)
  // "disabled" (default — no auto cycles), "dryRun" (auto cycles, log only), "enabled" (auto delete)
  autoRunMode                   String   @default("disabled")
  updatedAt                     DateTime @updatedAt
}

model SeedingRule {
  id                String   @id @default(cuid())
  name              String
  enabled           Boolean  @default(true)
  priority          Int      @default(0)
  categories        Json     @default("[]")
  trackerPatterns   Json     @default("[]")
  tagsAny           Json     @default("[]")
  tagsAll           Json     @default("[]")
  privacyType       String   @default("both")
  maxRatio          Float    @default(-1)
  minSeedTimeHours  Float    @default(0)
  maxSeedTimeHours  Float    @default(-1)
  deleteSourceFiles Boolean  @default(true)
  isSystem          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ==================== Cleanup: shared ====================

model CleanupStrike {
  id                  String   @id @default(cuid())
  hash                String
  torrentName         String
  ruleId              String?
  strikeType          String
  count               Int      @default(0)
  lastDownloadedBytes BigInt?
  lastSeenAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([hash, strikeType, ruleId])
  @@index([hash])
}

enum CleanupAction {
  strikeAdded
  removedFromClient
  removedFromQueue
  categoryChanged
  skipped
  dryRunPreview
  failed
}

model CleanupHistory {
  id              String        @id @default(cuid())
  cleaner         String
  strikeType      String?
  ruleId          String?
  ruleName        String?
  hash            String
  shortHash       String
  torrentName     String
  reason          String
  action          CleanupAction
  filesDeleted    Boolean
  reSearched      Boolean
  linkedArrSource String?
  linkedArrTitle  String?
  linkedArrItemId Int?
  torrentSize     BigInt?
  torrentProgress Float?
  torrentRatio    Float?
  triggeredBy     String
  errorMessage    String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([hash])
  @@index([action])
}
